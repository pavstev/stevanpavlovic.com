{
  "name": "spcom-final",
  "type": "module",
  "version": "0.0.1",
  "description": "Professional portfolio and technical blog built with Astro, TypeScript, and Tailwind CSS.",
  "author": "Stevan",
  "private": true,
  "keywords": [
    "astro",
    "portfolio",
    "blog",
    "typescript",
    "tailwindcss",
    "atomic-design"
  ],
  "scripts": {
    "clean": "find . -type d -empty -delete && git clean -Xfd -e .env.local && pnpm i",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "pnpm cf-typegen",
    "format": "prettier . -w",
    "build": "astro build",
    "dev": "astro dev",
    "preview": "wrangler dev",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "lint": "eslint . --cache --fix --max-warnings 0",
    "check": "astro check",
    "knip": "knip",
    "validate": "pnpm lint && pnpm check && pnpm knip",
    "all": "pnpm validate && pnpm build",
    "unlighthouse": "unlighthouse",
    "mini-all": "pnpm eslint ./src/components/ --cache --fix --max-warnings 0 && pnpm check && pnpm knip"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/cloudflare": "^12.6.12",
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/partytown": "^2.1.4",
    "@astrojs/react": "^4.4.2",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@iconify-json/mdi": "^1.2.3",
    "@nanostores/react": "^1.0.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-form": "^1.28.1",
    "@tanstack/zod-form-adapter": "^0.42.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^5.17.2",
    "astro-favicons": "^3.1.5",
    "astro-icon": "^1.1.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "framer-motion": "^12.34.0",
    "lucide-react": "^0.564.0",
    "motion": "^12.34.0",
    "nanostores": "^1.1.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-reading-time": "^2.0.2",
    "remark-toc": "^9.0.0",
    "tailwind-merge": "^3.4.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@astrojs/ts-plugin": "^1.10.6",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.6.0",
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "astro-eslint-parser": "^1.2.2",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-mdx": "^3.6.2",
    "eslint-plugin-astro": "^1.5.0",
    "eslint-plugin-better-tailwindcss": "^4.2.0",
    "eslint-plugin-markdownlint": "^0.9.0",
    "eslint-plugin-mdx": "^3.6.2",
    "eslint-plugin-perfectionist": "^5.5.0",
    "eslint-plugin-prefer-arrow-functions": "^3.9.1",
    "eslint-plugin-prettier": "^5.5.5",
    "jiti": "^2.6.1",
    "jsonc-eslint-parser": "^2.4.2",
    "knip": "^5.83.1",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "remark-lint-no-multiple-toplevel-headings": "^4.0.1",
    "shadcn": "^3.8.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript-eslint": "^8.55.0",
    "unlighthouse": "^0.17.4",
    "wrangler": "^4.65.0"
  }
}
