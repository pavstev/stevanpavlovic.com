---
import type { HTMLAttributes } from "astro/types";

import { cva, type VariantProps } from "class-variance-authority";

import type { ResponsiveValue } from "../../lib/types";

import { cn } from "../../lib/utils";

const gridVariants = cva("grid", {
  variants: {
    align: {
      baseline: "items-baseline",
      center: "items-center",
      end: "items-end",
      start: "items-start",
      stretch: "items-stretch",
    },
    justify: {
      around: "justify-around",
      between: "justify-between",
      center: "justify-center",
      end: "justify-end",
      evenly: "justify-evenly",
      start: "justify-start",
    },
  },
});

interface Props
  extends HTMLAttributes<"div">, Omit<VariantProps<typeof gridVariants>, "align" | "justify"> {
  align?: ResponsiveValue<VariantProps<typeof gridVariants>["align"]>;
  as?: any;
  cols?: ResponsiveValue<number | string>;
  gap?: ResponsiveValue<number | string>;
  justify?: ResponsiveValue<VariantProps<typeof gridVariants>["justify"]>;
  rows?: ResponsiveValue<number | string>;
}

const {
  align,
  as: Tag = "div",
  class: className,
  cols = 1,
  gap = 4,
  justify,
  rows,
  ...props
} = Astro.props;

/**
 * Local helper to build responsive utility classes without external dependency
 */
const buildResponsive = (value: ResponsiveValue<any>, prefix: string): string => {
  if (!value && value !== 0) return "";
  if (typeof value !== "object") return `${prefix}-${value}`;

  return cn(
    `${prefix}-${value.base}`,
    value.sm && `sm:${prefix}-${value.sm}`,
    value.md && `md:${prefix}-${value.md}`,
    value.lg && `lg:${prefix}-${value.lg}`,
    value.xl && `xl:${prefix}-${value.xl}`
  );
};

const colsClass = buildResponsive(cols, "grid-cols");
const rowsClass = rows ? buildResponsive(rows, "grid-rows") : "";
const gapClass = buildResponsive(gap, "gap");
const alignClass = buildResponsive(align, "items");
const justifyClass = buildResponsive(justify, "justify");
---

<Tag
  class:list={[cn("grid", colsClass, rowsClass, gapClass, alignClass, justifyClass, className)]}
  {...props}
>
  <slot />
</Tag>
