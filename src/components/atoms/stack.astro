---
import type { HTMLAttributes } from "astro/types";

import { cva, type VariantProps } from "class-variance-authority";

import type { ResponsiveValue } from "../../lib/types";

import { cn } from "../../lib/utils";

const stackVariants = cva("flex", {
    defaultVariants: {
        direction: "col",
    },
    variants: {
        align: {
            baseline: "items-baseline",
            center: "items-center",
            end: "items-end",
            start: "items-start",
            stretch: "items-stretch",
        },
        direction: {
            col: "flex-col",
            "col-reverse": "flex-col-reverse",
            row: "flex-row",
            "row-reverse": "flex-row-reverse",
        },
        justify: {
            around: "justify-around",
            between: "justify-between",
            center: "justify-center",
            end: "justify-end",
            evenly: "justify-evenly",
            start: "justify-start",
        },
        wrap: {
            nowrap: "flex-nowrap",
            wrap: "flex-wrap",
            "wrap-reverse": "flex-wrap-reverse",
        },
    },
});

interface Props
  extends HTMLAttributes<"div">, Omit<VariantProps<typeof stackVariants>, "align" | "direction" | "justify" | "wrap"> {
  align?: ResponsiveValue<VariantProps<typeof stackVariants>["align"]>;
  as?: any;
  direction?: ResponsiveValue<VariantProps<typeof stackVariants>["direction"]>;
  gap?: ResponsiveValue<number | string>;
  justify?: ResponsiveValue<VariantProps<typeof stackVariants>["justify"]>;
  wrap?: ResponsiveValue<VariantProps<typeof stackVariants>["wrap"]>;
}

const { align, as: Tag = "div", class: className, direction = "col", gap = 3, justify, wrap, ...rest } = Astro.props;

/**
 * Local helper to build responsive utility classes without external dependency
 */
const buildResponsive = (value: ResponsiveValue<any>, prefix: string): string => {
    if (!value && value !== 0) return "";
    if (typeof value !== "object") return `${prefix}-${value}`;

    return cn(
        `${prefix}-${value.base}`,
        value.sm && `sm:${prefix}-${value.sm}`,
        value.md && `md:${prefix}-${value.md}`,
        value.lg && `lg:${prefix}-${value.lg}`,
        value.xl && `xl:${prefix}-${value.xl}`,
    );
};

const directionClass = buildResponsive(direction, "flex")
    .replace(/flex-col/g, "flex-col")
    .replace(/flex-row/g, "flex-row");
const gapClass = buildResponsive(gap, "gap");
const alignClass = buildResponsive(align, "items");
const justifyClass = buildResponsive(justify, "justify");
const wrapClass = buildResponsive(wrap, "flex").replace(/flex-nowrap/g, "flex-nowrap");
---

<Tag
    class:list={[cn(stackVariants(), directionClass, alignClass, justifyClass, gapClass, wrapClass, className)]}
    {...rest}
>
    <slot />
</Tag>
