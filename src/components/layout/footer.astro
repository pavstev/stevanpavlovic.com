---
import { getCopyrightText } from "@client";
import { Icon } from "astro-icon/components";

import { SOCIALS } from "../../config";
import { Separator } from "../ui/separator";
---

<footer class="relative mt-6 mb-3 w-full" transition:persist>
  <div class="container mx-auto px-4">
    <div
      class="glass-strong hover:shadow-glow-subtle flex h-14 w-full items-center justify-between gap-3 rounded-full px-6 shadow-2xl transition-all duration-500 hover:border-foreground/20"
    >
      <p class="text-sm font-medium tracking-wide text-muted-foreground">
        {getCopyrightText()}
      </p>

      <div class="flex items-center gap-4">
        <div class="flex items-center gap-2 border-r border-foreground/10 pr-6">
          {
            SOCIALS.map((social) => (
              <a
                class="hover:shadow-glow-accent group flex items-center justify-center rounded-full p-2 text-muted-foreground transition-all duration-300 hover:scale-110 hover:bg-foreground/5 hover:text-foreground"
                data-tooltip={social.name}
                href={social.href}
                rel="noreferrer"
                target="_blank"
              >
                <Icon
                  class="size-6 group-hover:text-accent group-hover:drop-shadow-[0_0_8px_rgba(74,222,128,0.5)]"
                  name={social.icon}
                />
              </a>
            ))
          }
        </div>

        <Separator className="h-6" client:load orientation="vertical" />

        <a
          class="flex items-center gap-2 text-sm text-muted-foreground transition-colors hover:text-primary hover:drop-shadow-[0_0_8px_rgba(59,130,246,0.5)]"
          data-tooltip="RSS Feed"
          href="/rss.xml"
        >
          <Icon class="size-6" name="mdi:rss" />
        </a>
        <a
          class="flex items-center gap-2 text-sm text-muted-foreground transition-colors hover:text-primary hover:drop-shadow-[0_0_8px_rgba(59,130,246,0.5)]"
          data-tooltip="Sitemap"
          href="/sitemap-index.xml"
        >
          <Icon class="size-6" name="mdi:sitemap" />
        </a>
      </div>
    </div>
  </div>
</footer>
