---
import { NAV_ITEMS, NAV_ITEMS_ARRAY } from "../../config";
import { isActivePath } from "../../lib/nav";
import Button from "../atoms/Button.astro";
import Container from "../atoms/Container.astro";
import Stack from "../atoms/Stack.astro";
import BrandIdentity from "../molecules/BrandIdentity.astro";
import LanguagePicker from "../molecules/LanguagePicker.astro";
import MobileMenuToggle from "../molecules/mobile-menu-toggle.astro";
import MobileMenu from "../molecules/mobile-menu.astro";

const { pathname } = Astro.url;
const isActive = (href: string) => isActivePath(pathname, href);
const isPost = pathname.startsWith("/blog/") && pathname.length > 6;
---

<header
  class="fixed top-4 z-50 w-full px-4 transition-all duration-500 ease-in-out md:px-0"
  id="site-header"
  transition:persist
>
  <Container>
    <Stack align="center" class="justify-center" direction="row">
      {/* Dynamic Island Container */}
      <div
        class:list={[
          "glass-strong relative flex items-center gap-2 overflow-hidden px-2 shadow-2xl transition-all duration-700 ease-[cubic-bezier(0.34,1.56,0.64,1)]",
          "h-14 min-w-[320px] rounded-full border-white/5",
          "hover:border-primary/20",
        ]}
        id="nav-island"
      >
        {/* Progress Background (for posts) */}
        {
          isPost && (
            <div
              class="absolute inset-x-0 bottom-0 -z-10 h-1 w-0 bg-primary/20 transition-all duration-150"
              id="nav-progress-bg"
            />
          )
        }

        {/* Left: Brand / Logo */}
        <div class="flex shrink-0 items-center pl-1 transition-all duration-500" id="brand-wrapper">
          <BrandIdentity size="sm" variant="author" />
        </div>

        {/* Center: Desktop Nav */}
        <nav class="hidden items-center gap-1 transition-all duration-500 md:flex" id="desktop-nav">
          {
            NAV_ITEMS_ARRAY.map((item) => {
              const active = isActive(item.href);
              return (
                <Button
                  aria-current={active ? "page" : undefined}
                  class:list={[
                    "relative rounded-full px-4 py-2 text-[13px] font-bold transition-all duration-500",
                    {
                      "bg-primary/10 text-primary": active,
                      "text-muted-foreground hover:bg-white/5 hover:text-foreground": !active,
                    },
                  ]}
                  data-nav-link
                  href={item.href}
                >
                  <span class="relative z-10">{item.label}</span>
                  {active && (
                    <div
                      class="shadow-glow-primary/10 absolute inset-0 rounded-full bg-primary/5"
                      transition:name="nav-indicator"
                    />
                  )}
                </Button>
              );
            })
          }
        </nav>

        {/* Right: Actions */}
        <div class="ml-auto flex items-center gap-1 pr-1 transition-all duration-500" id="actions-wrapper">
          {/* Search Trigger */}
          <button
            aria-label="Search (Cmd+K)"
            class="flex size-9 items-center justify-center rounded-full text-muted-foreground transition-all duration-300 hover:bg-white/10 hover:text-foreground active:scale-90"
            data-search-trigger
          >
            <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"
            ><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg
            >
          </button>

          <div class="hidden md:block">
            <LanguagePicker />
          </div>

          <MobileMenuToggle size="sm" />
        </div>
      </div>
    </Stack>
  </Container>
</header>

<MobileMenu navItems={Object.values(NAV_ITEMS)} />

<script>
  import { initMobileMenu, updateActiveLinks } from "../../lib/mobile-menu";

  const init = () => {
    initMobileMenu();
    updateActiveLinks();

    const island = document.getElementById("nav-island");
    const progressBg = document.getElementById("nav-progress-bg");
    const brandWrapper = document.getElementById("brand-wrapper");
    const desktopNav = document.getElementById("desktop-nav");
    const actionsWrapper = document.getElementById("actions-wrapper");

    const handleScroll = () => {
      const scroll = window.scrollY;
      const isScrolled = scroll > 50;

      if (isScrolled) {
        // High-end state B: Compact Island
        island?.classList.add("h-11", "px-1.5", "scale-95", "border-primary/20", "bg-black/60");
        island?.classList.remove("h-14", "px-2");

        // Hide/Compact logic
        if (brandWrapper) brandWrapper.style.opacity = "0.7";
        if (desktopNav) desktopNav.style.gap = "0.25rem";
        if (actionsWrapper) actionsWrapper.style.opacity = "0.8";
      } else {
        // State A: Default
        island?.classList.remove("h-11", "px-1.5", "scale-95", "border-primary/20", "bg-black/60");
        island?.classList.add("h-14", "px-2");

        if (brandWrapper) brandWrapper.style.opacity = "1";
        if (desktopNav) desktopNav.style.gap = "0.5rem";
        if (actionsWrapper) actionsWrapper.style.opacity = "1";
      }

      // Progress bar logic
      if (progressBg) {
        const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
        const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
        progressBg.style.width = scrolled + "%";
      }
    };

    window.addEventListener("scroll", handleScroll, { passive: true });
    handleScroll();
  };

  init();
  document.addEventListener("astro:page-load", init);
</script>
