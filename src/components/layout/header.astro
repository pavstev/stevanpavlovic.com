---
import { isActivePath } from "@client";
import { cn } from "@client";

import { NAV_ITEMS_ARRAY } from "../../config";
import { Button } from "../ui/button";

const { pathname } = Astro.url;
const isActive = (href: string) => isActivePath(pathname, href);
const isPost = pathname.startsWith("/blog/") && pathname.length > 6;
---

<header
  class="fixed top-4 z-50 w-full transition-all duration-500 ease-in-out"
  id="site-header"
  transition:persist
>
  <div class="container mx-auto px-4">
    <div class="flex flex-row items-center justify-center gap-3">
      <div
        class={cn(
          "glass-strong relative flex items-center gap-2 overflow-hidden px-2 shadow-2xl transition-all duration-700 ease-[cubic-bezier(0.34,1.56,0.64,1)]",
          "h-14 min-w-80 rounded-full border-foreground/5",
          "hover:border-primary/20"
        )}
        id="nav-island"
      >
        {
          isPost && (
            <div
              class="absolute inset-x-0 bottom-0 -z-10 h-1 w-0 bg-primary/20 transition-all duration-150"
              id="nav-progress-bg"
            />
          )
        }

        <div class="flex shrink-0 items-center pl-1 transition-all duration-500" id="brand-wrapper">
          <a
            class="text-xl font-bold tracking-tighter transition-colors hover:text-primary"
            href="/"
          >
            SP
          </a>
        </div>

        <nav class="hidden items-center gap-1 transition-all duration-500 md:flex" id="desktop-nav">
          {
            NAV_ITEMS_ARRAY.map((item) => {
              const active = isActive(item.href);
              return (
                <Button data-nav-link href={item.href} isActive={active} size="xs" variant="ghost">
                  <p class="relative z-10">{item.label}</p>
                </Button>
              );
            })
          }
        </nav>

        <div
          class="ml-auto flex items-center gap-1 pr-1 transition-all duration-500 md:hidden"
          id="actions-wrapper"
        >
          {/* Mobile Menu Toggle was here */}
          <Button size="icon" variant="ghost">
            <span class="sr-only">Menu</span>
            <svg
              class="size-6"
              fill="none"
              height="24"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              viewBox="0 0 24 24"
              width="24"
              xmlns="http://www.w3.org/2000/svg"
              ><line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="6" y2="6"
              ></line><line x1="4" x2="20" y1="18" y2="18"></line></svg
            >
          </Button>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  import { updateActiveLinks } from "@client";
  import { initHeaderEffects } from "@client";

  const init = () => {
    updateActiveLinks();
    initHeaderEffects();
  };

  init();
  document.addEventListener("astro:page-load", init);
</script>
