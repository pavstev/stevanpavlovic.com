---
import { cn } from "@client/utils";

import { ScrollProgress } from "../ui/scroll-progress";
import { ToggleTheme } from "../ui/toggle-theme";
import { MainNav } from "./main-nav";
import { MobileNav } from "./mobile-nav";
---

<header
  class="fixed top-4 z-50 w-full transition-all duration-500 ease-in-out"
  id="site-header"
  transition:persist
>
  <div class="container mx-auto px-4">
    <div class="flex flex-row items-center justify-center gap-3">
      <div
        class={cn(
          "glass-strong hover:shadow-glow-subtle relative flex w-full items-center gap-2 px-2 shadow-2xl transition-all duration-500 ease-in-out",
          "h-14 rounded-full",
          "hover:border-foreground/20"
        )}
        id="nav-island"
      >
        <ScrollProgress
          className="absolute right-4 -bottom-px left-4 h-[2px] w-auto rounded-full bg-linear-to-r from-primary/50 via-primary to-primary/50"
          client:load
        />

        <div class="flex shrink-0 items-center transition-all duration-500" id="brand-wrapper">
          <a
            class={cn(
              "size-8 rounded-full bg-foreground/10 text-center text-lg leading-8 font-bold tracking-tighter transition-colors hover:scale-105 hover:bg-foreground hover:text-background"
            )}
            href="/"
          >
            SP
          </a>
        </div>

        <nav
          class="ml-auto hidden items-center gap-1 transition-all duration-500 md:flex"
          id="desktop-nav"
        >
          <MainNav client:load />
          <ToggleTheme client:load />
        </nav>

        <div
          class="ml-auto flex items-center gap-2 transition-all duration-500 md:hidden"
          id="actions-wrapper"
        >
          <MobileNav client:load />
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  import { updateActiveLinks } from "@client";
  import { initHeaderEffects } from "@client";

  const init = () => {
    updateActiveLinks();
    initHeaderEffects({
      afterScrollClasses: {
        add: ["h-11", "px-0", "pl-1.5", "pr-1", "border-primary/20", "bg-background/60"],
        remove: ["h-14", "px-2"],
      },
    });
  };

  init();
  document.addEventListener("astro:page-load", init);
</script>
