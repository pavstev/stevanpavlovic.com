---
import { cn } from "@client";

import { ToggleTheme } from "../ui/toggle-theme";
import { MainNav } from "./main-nav";
import { MobileNav } from "./mobile-nav";

const { pathname } = Astro.url;
const isPost = pathname.startsWith("/blog/") && pathname.length > 6;
---

<header
  class="fixed top-4 z-50 w-full transition-all duration-500 ease-in-out"
  id="site-header"
  transition:persist
>
  <div class="container mx-auto px-4">
    <div class="flex flex-row items-center justify-center gap-3">
      <div
        class={cn(
          "glass-strong hover:shadow-glow-subtle relative flex w-full items-center gap-2 px-6 shadow-2xl transition-all duration-500 ease-in-out",
          "h-14 rounded-full border-foreground/5",
          "hover:border-foreground/20"
        )}
        id="nav-island"
      >
        {
          isPost && (
            <div
              class="absolute inset-x-0 bottom-0 -z-10 h-1 w-0 bg-primary/20 transition-all duration-150"
              id="nav-progress-bg"
            />
          )
        }

        <div class="flex shrink-0 items-center transition-all duration-500" id="brand-wrapper">
          <a
            class="text-xl font-bold tracking-tighter transition-colors hover:text-primary"
            href="/"
          >
            SP
          </a>
        </div>

        <nav
          class="ml-auto hidden items-center gap-1 transition-all duration-500 md:flex"
          id="desktop-nav"
        >
          <MainNav client:load />
          <ToggleTheme client:load />
        </nav>

        <div
          class="ml-auto flex items-center gap-2 transition-all duration-500 md:hidden"
          id="actions-wrapper"
        >
          <MobileNav client:load />
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  import { updateActiveLinks } from "@client";
  import { initHeaderEffects } from "@client";

  const init = () => {
    updateActiveLinks();
    initHeaderEffects();
  };

  init();
  document.addEventListener("astro:page-load", init);
</script>
