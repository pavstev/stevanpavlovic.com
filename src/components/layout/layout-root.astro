---
import "../../styles/global.css";
import "@fontsource-variable/space-grotesk";
import "@fontsource-variable/inter";
import "@fontsource-variable/jetbrains-mono";
import { ClientRouter } from "astro:transitions";

import Analytics from "../atoms/Analytics.astro";
import MetaData from "../atoms/MetaData.astro";

export interface Props {
  description: string;
  image?: URL;
  lang?: string;
  title: string;
}

const { description, image, lang = "en", title } = Astro.props;
---

<!doctype html>
<html class="scroll-smooth" lang={lang}>
  <head>
    <MetaData description={description} image={image} title={title} />
    <Analytics />
    <ClientRouter />
    <slot name="head" />
  </head>
  <body class="bg-(--color-background) text-(--color-foreground) antialiased selection:bg-(--color-primary/20)">
    <slot />
  </body>
</html>
