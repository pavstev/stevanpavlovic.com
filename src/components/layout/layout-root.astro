---
import type { HTMLAttributes } from "astro/types";

import { cn } from "@client/utils";
import "../../styles/global.css";
import "@fontsource-variable/space-grotesk";
import "@fontsource-variable/inter";
import "@fontsource-variable/jetbrains-mono";
import { ClientRouter } from "astro:transitions";

import Analytics from "../atoms/analytics.astro";
import Container from "../atoms/container.astro";
import MetaHead from "../atoms/meta-head.astro";
import EnvironmentalBackground from "../organisms/environmental-background.astro";
import Footer from "./footer.astro";
import Header from "./header.astro";

interface Props extends HTMLAttributes<"html"> {
  description: string;
  image?: URL;
  intensity?: "high" | "low" | "medium";
  lang?: string;
  slug?: string;
  title: string;
}

const {
  class: className,
  description,
  image,
  intensity = "medium",
  lang = "en",
  title,
  ...rest
} = Astro.props;

const googleAnalyticsID = import.meta.env.PUBLIC_GTM_ID;
---

<!doctype html>
<html class="scroll-smooth" lang={lang} {...rest}>
  <head>
    <meta content="nosniff" http-equiv="X-Content-Type-Options" />
    <meta content="DENY" http-equiv="X-Frame-Options" />
    <meta content="camera=(), microphone=(), geolocation=()" http-equiv="Permissions-Policy" />
    <MetaHead description={description} image={image} title={title} />
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin href="https://fonts.gstatic.com" rel="preconnect" />
    {!!googleAnalyticsID && <Analytics googleAnalyticsID={googleAnalyticsID} />}
    <ClientRouter />
    <slot name="head" />
  </head>
  <body
    class={cn(
      "bg-background",
      "text-foreground",
      "antialiased",
      "selection:bg-primary/20",
      "selection:text-foreground",
      className
    )}
  >
    <EnvironmentalBackground {intensity} />

    <Header />
    <main class="relative z-10 min-h-screen">
      <Container>
        <slot />
      </Container>
    </main>
    <Footer />
  </body>
</html>
