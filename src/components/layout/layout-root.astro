---
import type { HTMLAttributes } from "astro/types";

import "../../styles/global.css";
import "@fontsource-variable/space-grotesk";
import "@fontsource-variable/inter";
import "@fontsource-variable/jetbrains-mono";
import { ClientRouter } from "astro:transitions";

import Analytics from "../atoms/Analytics.astro";
import MetaData from "../atoms/MetaData.astro";
import Chatbot from "../molecules/chatbot.astro";
import EnvironmentalBackground from "../organisms/EnvironmentalBackground.astro";
import OmniSearch from "../organisms/OmniSearch.astro";
import Footer from "./footer.astro";
import Header from "./header.astro";

interface Props extends HTMLAttributes<"html"> {
  description: string;
  image?: URL;
  intensity?: "high" | "low" | "medium";
  lang?: string;
  slug?: string;
  title: string;
}

const { class: className, description, image, intensity = "medium", lang = "en", title, ...rest } = Astro.props;
---

<!doctype html>
<html class="scroll-smooth" lang={lang} {...rest}>
  <head>
    <meta content="nosniff" http-equiv="X-Content-Type-Options" />
    <meta content="DENY" http-equiv="X-Frame-Options" />
    <meta content="camera=(), microphone=(), geolocation=()" http-equiv="Permissions-Policy" />
    <MetaData description={description} image={image} title={title} />
    <Analytics />
    <ClientRouter />
    <slot name="head" />
  </head>
  <body
    class:list={[
      "bg-background",
      "text-foreground",
      "antialiased",
      "selection:bg-primary/20",
      "selection:text-foreground",
      className,
    ]}
  >
    <EnvironmentalBackground {intensity} />

    <Header />
    <main class="relative z-10 min-h-screen">
      <slot />
    </main>
    <Footer />
    <Chatbot />
    <OmniSearch />

    <script>
      import { initEasterEggs } from "../../lib/easter-eggs";
      initEasterEggs();
      document.addEventListener("astro:page-load", initEasterEggs);
    </script>

    <style is:global>
      /* Scifi Custom Scrollbar Implementation */
      :root {
        --scrollbar-width: 6px;
        --scrollbar-thumb-color: var(--color-primary);
        --scrollbar-thumb-glow: 0 0 10px var(--color-primary);
      }

      ::-webkit-scrollbar {
        height: var(--scrollbar-width);
        width: var(--scrollbar-width);
      }

      ::-webkit-scrollbar-track {
        background: transparent;
      }

      ::-webkit-scrollbar-thumb {
        background: var(--scrollbar-thumb-color);
        border-radius: 10px;
        box-shadow: var(--scrollbar-thumb-glow);
      }

      ::-webkit-scrollbar-thumb:hover {
        background: var(--color-accent);
      }

      /* Selection Glow Effect */
      ::selection {
        background-color: color-mix(in srgb, var(--color-primary), transparent 80%);
        text-shadow: 0 0 8px var(--color-primary);
      }

      /* Focus Visible Ring */
      :focus-visible {
        outline: 2px solid var(--color-primary);
        outline-offset: 2px;
      }
    </style>
  </body>
</html>
