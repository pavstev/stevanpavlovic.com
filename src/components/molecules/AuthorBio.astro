---
import { PROFILE, SOCIALS } from "../../config";
import Avatar from "../atoms/Avatar.astro";
import Heading from "../atoms/Heading.astro";
import Icon from "../atoms/Icon.astro";
import Separator from "../atoms/Separator.astro";
import Stack from "../atoms/Stack.astro";
import Text from "../atoms/Text.astro";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<Stack class:list={["glass rounded-2xl border-white/5 p-6", className]} gap={6}>
  <Stack align="center" direction="row" gap={4}>
    <Avatar alt={PROFILE.name} size="lg" src={PROFILE.avatar} />
    <Stack gap={0.5}>
      <Heading level={4} size="sm">{PROFILE.name}</Heading>
      <Text size="xs" variant="muted">{PROFILE.role}</Text>
    </Stack>
  </Stack>

  <Text class="leading-relaxed" size="sm" variant="muted">
    {PROFILE.bio.split('.').slice(0, 2).join('.')}.
  </Text>

  <Separator class="opacity-50" />

  <div class="flex gap-3">
    {SOCIALS.map(social => (
      <a
        aria-label={social.name}
        class="flex size-8 items-center justify-center rounded-full border border-white/10 bg-white/5 text-muted-foreground transition-all hover:border-primary/30 hover:text-primary"
        href={social.href}
      >
        <Icon name={social.icon} size="sm" />
      </a>
    ))}
  </div>
</Stack>
