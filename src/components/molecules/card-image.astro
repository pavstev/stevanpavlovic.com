---
import type { ImageMetadata } from "astro";
import type { HTMLAttributes } from "astro/types";

import { cn } from "@client/utils";
import { Image } from "astro:assets";

interface Props extends HTMLAttributes<"div"> {
  alt?: string;
  class?: string;
  image: ImageMetadata | string;
  loading?: "eager" | "lazy";
  wrapperClass?: string;
}

const { alt = "", class: className, image, loading = "lazy", wrapperClass, ...rest } = Astro.props;
---

<div
  class={cn(
    "relative shrink-0 overflow-hidden rounded-xl border border-border/50 bg-muted",
    wrapperClass
  )}
  {...rest}
>
  {
    typeof image === "string" ? (
      <img
        alt={alt}
        class={cn(
          "size-full object-cover transition-transform duration-500 group-hover:scale-[1.05]",
          className
        )}
        loading={loading}
        src={image}
      />
    ) : (
      <Image
        alt={alt}
        class={cn(
          "size-full object-cover transition-transform duration-500 group-hover:scale-[1.05]",
          className
        )}
        format="avif"
        loading={loading}
        src={image}
        widths={[400, 800]}
      />
    )
  }
  {/* Overlay for subtle depth */}
  <div
    class="pointer-events-none absolute inset-0 bg-linear-to-t from-black/20 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"
  >
  </div>
</div>
