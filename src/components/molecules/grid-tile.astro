---
import { cn } from "@client";

import SpotlightEffect from "../atoms/spotlight-effect.astro";

interface Props {
  class?: string;
  cols?: string;
  rows?: string;
}

const { class: className, cols = "col-span-1", rows = "row-span-1" } = Astro.props;
---

<div
  class={cn(
    "group/card relative overflow-hidden rounded-2xl border border-foreground/5 bg-foreground/5 p-6 backdrop-blur-md transition-all duration-300",
    cols,
    rows,
    className
  )}
>
  <SpotlightEffect class="opacity-0" />
  <slot />
</div>
