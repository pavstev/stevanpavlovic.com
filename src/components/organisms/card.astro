---
import type { CardData } from "@server/types";
import type { HTMLAttributes } from "astro/types";

import { cn } from "@client";
import { Image } from "astro:assets";
import { cva, type VariantProps } from "class-variance-authority";

import Badge from "../atoms/badge.astro";
import DateTime from "../atoms/date-time.astro";
import Heading from "../atoms/heading.astro";
import Icon from "../atoms/icon.astro";
import CardSpotlight from "../atoms/spotlight-effect.astro";
import Text from "../atoms/text.astro";
import CardImage from "../molecules/card-image.astro";
import IconBox from "../molecules/icon-box.astro";
import LabelGroup from "../molecules/label-group.astro";

const variants = cva(
  "group/card relative flex w-full flex-col overflow-hidden rounded-2xl border bg-card transition-all duration-300",
  {
    defaultVariants: {
      interactive: false,
      variant: "default",
    },
    variants: {
      interactive: {
        false: "",
        true: "cursor-pointer hover:-translate-y-1 hover:shadow-2xl hover:shadow-primary/5",
      },
      variant: {
        default: "border-border/50 backdrop-blur-md hover:border-primary/20",
        ghost: "border-transparent hover:bg-foreground/5",
        glass: "glass-dark border-foreground/5 hover:bg-foreground/5",
        outline: "border-2 border-border/50 hover:border-primary/20",
      },
    },
  }
);

interface BaseProps extends HTMLAttributes<"div">, Omit<VariantProps<typeof variants>, "variant"> {
  as?: any;
  glowColor?: string;
  visual?: "default" | "ghost" | "glass" | "outline";
}

interface Props extends BaseProps {
  actionIcon?: string;
  actionLabel?: string;
  data?: CardData;
  headingLevel?: number;
  list?: boolean;
  loading?: "eager" | "lazy";
  showVisual?: boolean;
}

const props = Astro.props;
const {
  actionIcon = "mdi:arrow-right",
  actionLabel,
  class: className,
  data: _data,
  glowColor = "var(--color-primary)",
  headingLevel = 3,
  interactive,
  list,
  loading,
  showVisual = true,
  visual = "default",
  ...rest
} = props;

const data = _data ?? {};

const {
  align = "start",
  animate,
  date,
  delay = 0,
  description,
  footerMeta,
  icon,
  image,
  logo,
  meta,
  subtitle,
  tags,
  title,
  url,
} = data;

const Wrapper = (url ? "a" : "div") as any;
const cardClasses = variants({ className, interactive: !!url ?? interactive, variant: visual });

const isRowLayout = list && !icon;
---

<Wrapper class={cn("group block", !isRowLayout && "h-full")} href={url} {...rest}>
  <div
    class={cn(
      cardClasses,
      { "flex-row gap-4 p-4": isRowLayout, "h-full flex-col gap-4 p-5 sm:p-6": !isRowLayout },
      {
        "items-center text-center": align === "center" && !isRowLayout,
        "items-start": !(align === "center" && !isRowLayout),
      },
      animate && "animate-in fade-in slide-in-from-bottom-4 duration-700"
    )}
    style={{ "--glow-color": glowColor, animationDelay: `${delay}ms` }}
  >
    <CardSpotlight glowColor={glowColor} />

    {
      icon && (
        <div class="relative shrink-0">
          <div class="absolute -inset-4 bg-primary/10 opacity-0 blur-2xl transition-opacity duration-500 group-hover:opacity-100" />
          <IconBox
            class="relative border-border/50 bg-foreground/5 group-hover:border-primary/30 group-hover:bg-primary/5"
            icon={icon}
            iconSize="lg"
            size="lg"
            variant="default"
          />
        </div>
      )
    }

    {
      image && showVisual && (
        <CardImage
          alt={title ?? ""}
          image={image}
          loading={loading}
          wrapperClass={
            isRowLayout ? "hidden size-20 shrink-0 sm:block" : "mb-2 aspect-video w-full rounded-xl"
          }
        />
      )
    }

    {
      logo && (
        <div class="relative shrink-0">
          <div class="absolute -inset-4 bg-primary/10 opacity-0 blur-2xl transition-opacity duration-500 group-hover:opacity-100" />
          <div class="relative flex size-14 items-center justify-center overflow-hidden rounded-xl border border-border/50 bg-foreground/5 transition-all duration-300 group-hover:scale-105 group-hover:border-primary/30 group-hover:bg-primary/5">
            <Image
              alt={title ?? ""}
              class="size-full object-contain p-2"
              format="avif"
              src={logo}
              widths={[128]}
            />
          </div>
        </div>
      )
    }

    <div
      class={cn("flex w-full min-w-0 flex-1 flex-col", {
        "gap-1": isRowLayout,
        "gap-3": !isRowLayout,
      })}
    >
      <div
        class={cn("flex w-full justify-between gap-2", {
          "flex-col sm:flex-row": !isRowLayout,
          "flex-row": isRowLayout,
        })}
      >
        <div class={cn("flex flex-col", { "gap-0": isRowLayout, "gap-1": !isRowLayout })}>
          {
            date && (
              <Text class="font-mono tracking-wider uppercase opacity-70" size="xs" variant="muted">
                <DateTime date={date} />
              </Text>
            )
          }

          <Heading
            class={cn("transition-colors group-hover:text-primary", {
              "line-clamp-2": !isRowLayout,
              "mt-1 line-clamp-1": isRowLayout,
            })}
            level={headingLevel as 1 | 2 | 3 | 4 | 5 | 6}
            size={isRowLayout ? "sm" : "md"}
          >
            {title}
          </Heading>

          {
            subtitle && (
              <Text class="mt-0.5 font-mono tracking-wider uppercase" size="xs" variant="muted">
                {subtitle}
              </Text>
            )
          }
        </div>

        <div
          class={cn(
            "flex items-center gap-2 self-start",
            align === "center" && !isRowLayout && "hidden"
          )}
        >
          {meta && <Badge variant="default">{meta}</Badge>}

          {
            url && (
              <div class="relative flex min-h-6 min-w-6 items-center justify-end font-mono">
                <div
                  class={cn(
                    "absolute right-0 flex items-center text-muted-foreground transition-all duration-300",
                    {
                      "group-hover:-translate-x-2 group-hover:opacity-0": actionLabel,
                      "group-hover:translate-x-1 group-hover:-translate-y-1 group-hover:text-primary":
                        !actionLabel,
                    }
                  )}
                >
                  <Icon name="mdi:arrow-top-right" size="sm" />
                </div>
                {actionLabel && (
                  <div class="flex items-center gap-1 text-[10px] font-bold tracking-widest text-primary uppercase opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100">
                    {actionLabel}
                    <Icon name={actionIcon} size="sm" />
                  </div>
                )}
              </div>
            )
          }
        </div>
      </div>

      {
        description && (
          <Text
            class={cn("text-muted-foreground", {
              "mt-1.5 line-clamp-3 flex-1": !isRowLayout,
              "mt-2 line-clamp-1": isRowLayout,
            })}
            size="sm"
          >
            {description}
          </Text>
        )
      }

      <div
        class="mt-auto flex items-center justify-between gap-4 border-t border-foreground/5 pt-4"
      >
        {tags && tags.length > 0 && <LabelGroup items={tags} limit={isRowLayout ? 4 : 3} />}

        {
          footerMeta && (
            <Text
              class="font-mono tracking-wider whitespace-nowrap uppercase transition-colors group-hover:text-primary/80"
              size="xs"
              variant="muted"
            >
              {footerMeta}
            </Text>
          )
        }
      </div>
    </div>
  </div>
</Wrapper>

<script>
  import { initInteractiveCards } from "@client";

  const init = () => {
    initInteractiveCards();
  };

  init();
  document.addEventListener("astro:page-load", init);
</script>
