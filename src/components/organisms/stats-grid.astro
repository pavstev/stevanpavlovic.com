---
import type { HTMLAttributes } from "astro/types";

import Grid from "../atoms/grid.astro";
import MetricBlock from "../molecules/metric-block.astro";

interface Props extends HTMLAttributes<"div"> {
  items: readonly StatItem[];
}

interface StatItem {
  format?: "compact" | "plain";
  icon: string;
  label: string;
  unit?: string;
  value: number;
}

const { class: className, items, ...props } = Astro.props;
---

<Grid cols={{ base: 1, lg: 3, md: 2 }} gap={4} {...props}>
  {
    items.map((item) => (
      <MetricBlock
        class="origin-left transition-transform duration-300 hover:scale-105"
        format={item.format}
        icon={item.icon}
        label={item.label}
        unit={item.unit}
        value={item.value}
      />
    ))
  }
</Grid>
