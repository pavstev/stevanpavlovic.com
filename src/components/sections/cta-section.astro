---
import { CTA_CONTENT } from "../../config";
import Heading from "../atoms/heading.astro";
import Stack from "../atoms/stack.astro";
import Text from "../atoms/text.astro";
import GridTile from "../molecules/grid-tile.astro";
---

<GridTile class="border-primary/10 bg-primary/5 p-8 lg:col-span-12">
  <div class="flex flex-col items-center justify-between gap-8 md:flex-row">
    <Stack gap={2}>
      <Heading level={3} size="md">{CTA_CONTENT.title}</Heading>
      <Text variant="muted">{CTA_CONTENT.description}</Text>
    </Stack>
    <div class="flex gap-4">
      <a
        class="hover:shadow-glow-primary rounded-full bg-primary px-6 py-3 font-bold text-foreground transition-all"
        href="/projects">{CTA_CONTENT.browseProjects}</a
      >
      <a
        class="rounded-full border border-foreground/10 bg-foreground/5 px-6 py-3 font-bold text-foreground transition-all hover:bg-foreground/10"
        href="/blog">{CTA_CONTENT.readBlog}</a
      >
    </div>
  </div>
</GridTile>
