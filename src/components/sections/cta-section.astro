---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import Heading from "../atoms/heading.astro";
import Stack from "../atoms/stack.astro";
import Text from "../atoms/text.astro";
import GridTile from "../molecules/grid-tile.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<GridTile class="border-primary/10 bg-primary/5 p-8 lg:col-span-12">
  <div class="flex flex-col items-center justify-between gap-8 md:flex-row">
    <Stack gap={2}>
      <Heading level={3} size="md">{t("cta.title")}</Heading>
      <Text variant="muted">{t("cta.description")}</Text>
    </Stack>
    <div class="flex gap-4">
      <a
        class="hover:shadow-glow-primary rounded-full bg-primary px-6 py-3 font-bold text-white transition-all"
        href="/projects">{t("cta.browseProjects")}</a
      >
      <a
        class="rounded-full border border-white/10 bg-white/5 px-6 py-3 font-bold text-white transition-all hover:bg-white/10"
        href="/blog">{t("cta.readBlog")}</a
      >
    </div>
  </div>
</GridTile>
