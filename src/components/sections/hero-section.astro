---
import profileImg from "../../assets/profile.jpeg";
import { PROFILE, SITE_CONFIG, STATS } from "../../config";
import Heading from "../atoms/heading.astro";
import Text from "../atoms/text.astro";
import GridTile from "../molecules/grid-tile.astro";
import StatsGrid from "../organisms/stats-grid.astro";
---

<GridTile class="overflow-hidden p-6 md:p-10 lg:col-span-12">
  {/* Animated Gradient Background */}
  <div class="absolute inset-0 -z-10 bg-gradient-animated"></div>

  <div class="relative z-10 flex flex-col gap-5 items-center text-center">
    {/* Brand Core */}
    <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-center w-full">
      <div class="flex-1 max-w-2xl">
        <Heading class="leading-header tracking-tight" level={1} size="display" variant="primary">
          {SITE_CONFIG.hero.title}
        </Heading>
        <Text class="mt-3 text-base text-muted-foreground/90 md:text-lg">
          {SITE_CONFIG.description}
        </Text>
      </div>

      {/* Profile Image */}
      <div class="shrink-0 self-center mt-4 md:mt-0 md:ml-8">
        <div
          class="relative size-32 overflow-hidden rounded-full bg-foreground/5 ring-4 ring-background md:size-40 animate-fade-in"
        >
          <img alt={PROFILE.name} class="size-full object-cover" src={profileImg.src} />
        </div>
      </div>
    </div>

    {/* Stats */}
    <div class="pt-3 w-full">
      <StatsGrid items={STATS} />
    </div>
  </div>
</GridTile>
