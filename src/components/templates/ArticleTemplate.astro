---
import { cn } from "../../lib/cn";
import Prose from "../atoms/Prose.astro";
import Stack from "../atoms/Stack.astro";
import MetaBar from "../molecules/MetaBar.astro";
import ArticleRenderer from "../organisms/ArticleRenderer.astro";

export interface Props {
  class?: string;
  metadata: {
    description?: string;
    tags?: unknown;
    toolbarItems?: unknown[];
  };
}

const { class: className, metadata } = Astro.props;
const hasToc = Astro.slots.has("toc");
const hasRelated = Astro.slots.has("related");
---

<ArticleRenderer class:list={cn("pt-16 md:pt-24", className)}>
  {/* Position 1: The Context Layer (Hero & Shared Meta) */}
  <Stack class="mb-12" gap={8} slot="header">
    <slot name="hero" />
    <MetaBar
      description={metadata.description}
      tags={metadata.tags}
      toolbarItems={metadata.toolbarItems}
    />
  </Stack>

  {/* Position 2: Table of Contents (Dynamic Slot Detection) */}
  {hasToc && (
    <div slot="toc">
      <slot name="toc" />
    </div>
  )}

  {/* Position 3: The Content Core */}
  <Prose variant="cyber">
    <slot />
  </Prose>

  {/* Position 4: Related Discovery Region */}
  {hasRelated && (
    <div class="mt-20 border-t border-white/5 pt-10" slot="footer">
      <slot name="related" />
    </div>
  )}
</ArticleRenderer>
