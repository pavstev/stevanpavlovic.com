---
import type { HTMLAttributes } from "astro/types";

import { cn } from "../../lib/cn";
import Prose from "../atoms/Prose.astro";
import Stack from "../atoms/Stack.astro";
import MetaBar from "../molecules/MetaBar.astro";
import ArticleRenderer from "../organisms/ArticleRenderer.astro";

export interface Props extends HTMLAttributes<"article"> {
  class?: string;
  metadata: {
    description?: string;
    tags?: unknown;
    toolbarItems?: unknown[];
  };
}

const {
  class: className,
  metadata,
  ...rest
} = Astro.props;

const hasToc = Astro.slots.has("toc");
const hasRelated = Astro.slots.has("related");
const hasHero = Astro.slots.has("hero");
---

<ArticleRenderer
  class:list={[
    cn(
      "pt-16",
      "md:pt-24",
      "pb-20",
      className,
    ),
  ]}
  {...rest}
>
  <!-- Position 1: The Context Layer (Hero & Shared Meta) -->
  {hasHero && (
    <Stack
      class="mb-12"
      gap={8}
      slot="header"
    >
      <slot name="hero" />
      <MetaBar
        description={metadata.description}
        tags={metadata.tags}
        toolbarItems={metadata.toolbarItems}
      />
    </Stack>
  )}

  <!-- Position 2: Progress Navigation (TOC) -->
  {hasToc && (
    <div slot="toc">
      <slot name="toc" />
    </div>
  )}

  <!-- Position 3: The Content Core -->
  <Prose variant="cyber">
    <slot />
  </Prose>

  <!-- Position 4: Related Discovery Region -->
  {hasRelated && (
    <div
      class:list={[
        "mt-20",
        "pt-10",
        "border-t",
        "border-white/5",
      ]}
      slot="footer"
    >
      <slot name="related" />
    </div>
  )}
</ArticleRenderer>
