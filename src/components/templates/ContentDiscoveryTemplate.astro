---
import { cn } from "../../lib/cn";
import Heading from "../atoms/Heading.astro";
import Stack from "../atoms/Stack.astro";
import Text from "../atoms/Text.astro";
import CompositionGrid from "../organisms/CompositionGrid.astro";

export interface Props {
  class?: string;
  description?: string;
  title: string;
}

const { class: className, description, title } = Astro.props;
const hasFilters = Astro.slots.has("filters");
const hasSidebar = Astro.slots.has("sidebar");
---

<CompositionGrid as="main" class:list={cn("py-20 md:pt-32", className)}>
  {/* Header Section: Discovery Blueprint */}
  <Stack class="mb-16" gap={4}>
    <Heading level={1} size="display" variant="primary">
      {title}
    </Heading>
    {description && (
      <Text class="max-w-3xl text-xl leading-relaxed" variant="muted">
        {description}
      </Text>
    )}

    {hasFilters && (
      <div class="mt-8 flex flex-wrap gap-4">
        <slot name="filters" />
      </div>
    )}
  </Stack>

  {/* Content Layer: Responsive Discovery Grid */}
  <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
    <slot />
  </div>

  {/* Optional Discovery Sidebar */}
  {hasSidebar && (
    <div class="flex flex-col gap-10" slot="sidebar">
      <slot name="sidebar" />
    </div>
  )}
</CompositionGrid>
