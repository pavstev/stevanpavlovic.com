---
import type { HTMLAttributes } from "astro/types";

import { cn } from "../../lib/cn";
import Heading from "../atoms/Heading.astro";
import Stack from "../atoms/Stack.astro";
import Text from "../atoms/Text.astro";
import CompositionGrid from "../organisms/CompositionGrid.astro";

export interface Props extends HTMLAttributes<"main"> {
  class?: string;
  description?: string;
  title: string;
}

const {
  class: className,
  description,
  title,
  ...rest
} = Astro.props;

const hasFilters = Astro.slots.has("filters");
const hasSidebar = Astro.slots.has("sidebar");
---

<CompositionGrid
  as="main"
  class:list={[
    cn(
      "pt-20",
      "md:pt-32",
      "pb-20",
      className,
    ),
  ]}
  {...rest}
>
  <!-- Header Section: Discovery Blueprint -->
  <Stack
    class="mb-16"
    gap={4}
  >
    <Heading
      level={1}
      size="display"
      variant="primary"
    >
      {title}
    </Heading>

    {description && (
      <Text
        class:list={[
          "text-xl",
          "leading-relaxed",
          "max-w-3xl",
        ]}
        variant="muted"
      >
        {description}
      </Text>
    )}

    <!-- Dynamic Filter Controls -->
    {hasFilters && (
      <div
        class:list={[
          "mt-8",
          "flex",
          "flex-wrap",
          "gap-4",
        ]}
      >
        <slot name="filters" />
      </div>
    )}
  </Stack>

  <!-- Content Layer: Responsive Discovery Grid -->
  <div
    class:list={[
      "grid",
      "gap-8",
      "grid-cols-1",
      "md:grid-cols-2",
      "lg:grid-cols-3",
    ]}
  >
    <slot />
  </div>

  <!-- Optional Discovery Sidebar -->
  {hasSidebar && (
    <div
      class:list={[
        "flex",
        "flex-col",
        "gap-10",
      ]}
      slot="sidebar"
    >
      <slot name="sidebar" />
    </div>
  )}
</CompositionGrid>
