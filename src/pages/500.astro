---
import { Icon } from "astro-icon/components";

import LayoutRoot from "../components/layout/layout-root.astro";
import { Button } from "../components/ui/button";

interface Props {
  error: unknown;
}

const { error } = Astro.props;

const title = "500 - System Critical";
const description = "An unexpected error occurred while processing your request.";
const errorMessage = error instanceof Error ? error.message : "Unknown System Exception";
---

<LayoutRoot description={description} slug="/500" title={title}>
  <!-- Background removed -->

  <div
    class="relative flex min-h-[calc(100vh-12rem)] min-w-full flex-col items-center justify-center"
  >
    <div
      class="relative z-10 container mx-auto flex flex-col items-center justify-center p-6 px-4 sm:p-8"
    >
      <div
        class="glass-strong flex flex-col items-center gap-6 rounded-2xl border border-danger/20 p-6 text-center shadow-2xl shadow-danger/10 sm:p-8"
      >
        <div class="relative">
          <h1 class="text-9xl font-black tracking-tighter text-danger opacity-90 sm:text-[12rem]">
            500
          </h1>
          <div class="shadow-glow-danger absolute inset-0 -z-10 opacity-30 blur-3xl"></div>
        </div>

        <div class="flex flex-col items-center gap-4">
          <h2 class="text-3xl font-bold tracking-tight text-danger capitalize lg:text-4xl">
            System Malfunction
          </h2>

          <p class="text-lg text-balance text-muted-foreground">
            The server successfully processed 0% of your request. An anomaly has been detected in
            the core logic.
          </p>

          <div
            class="mt-2 rounded-lg border border-foreground/5 bg-background/40 px-4 py-2 font-mono text-xs text-red-400"
          >
            Error: {errorMessage}
          </div>
        </div>

        <div class="flex w-full flex-col gap-3 sm:flex-row sm:justify-center">
          <Button as="a" className="w-full sm:w-auto" href="/" size="lg" variant="default">
            <Icon class="mr-2 size-6" name="mdi:home-lightning-bolt-outline" />
            Return to Base
          </Button>
          <Button as="a" className="w-full sm:w-auto" href="/" size="lg" variant="outline">
            <Icon class="mr-2 size-6" name="mdi:restart" />
            Retry Sequence
          </Button>
        </div>
      </div>
    </div>
  </div>
</LayoutRoot>
