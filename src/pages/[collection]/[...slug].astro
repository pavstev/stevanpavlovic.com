---
import type { GetStaticPathsItem, GetStaticPathsResult } from "astro";
import type { CollectionEntry, CollectionKey } from "astro:content";

import { getViewPageProps } from "@server/api";
import { collections } from "@server/types";
import { getCollection, render } from "astro:content";

import Heading from "../../components/atoms/heading.astro";
import LayoutRoot from "../../components/layout/layout-root.astro";
import NavigationProgress from "../../components/layout/navigation-progress.astro";
import MetaBar from "../../components/molecules/meta-bar.astro";
import ArticleRenderer from "../../components/organisms/article-renderer.astro";
import TableOfContents from "../../components/organisms/table-of-contents.astro";

export const prerender = true;

type Props = CollectionEntry<CollectionKey>;

export async function getStaticPaths(): Promise<GetStaticPathsResult> {
  const result = await Promise.all(
    collections.map(async (collection): Promise<GetStaticPathsItem[]> => {
      const items = await getCollection(collection);

      return items.map((item): GetStaticPathsItem => {
        const { collection, id: slug } = item;
        return {
          params: { collection, slug },
          props: item,
        };
      });
    })
  );

  return result.flat();
}

const entry = Astro.props as Props;
const { collection } = Astro.params;

if (entry === undefined) {
  return Astro.redirect("/404");
}

const { Content, headings } = await render(entry);
const viewProps = await getViewPageProps(entry as any);
---

<LayoutRoot
  description={viewProps.description ?? ""}
  slug={`/${collection}/${entry.id}`}
  title={viewProps.title}
>
  <NavigationProgress />

  <ArticleRenderer class="py-12 md:py-24" showSidebar={headings.length > 0}>
    <header
      class="animate-in fade-in slide-in-from-bottom-4 flex flex-col gap-8 duration-700"
      slot="header"
    >
      <Heading class="leading-header tracking-tight" level={1} size="display">
        {viewProps.title}
      </Heading>
      <MetaBar
        description={viewProps.description}
        tags={viewProps.tags}
        toolbarItems={viewProps.toolbarItems}
      />
    </header>

    {headings.length > 0 && <TableOfContents slot="toc" title="Inside the Article" />}

    <div
      class="prose-primary prose max-w-none transition-all prose-invert prose-headings:font-bold prose-a:text-primary hover:prose-a:brightness-125 prose-code:text-primary"
    >
      <Content />
    </div>
  </ArticleRenderer>
</LayoutRoot>

<script>
  import { initFocusMode } from "@client";

  const init = () => {
    initFocusMode();
  };

  init();
  document.addEventListener("astro:page-load", init);
</script>
