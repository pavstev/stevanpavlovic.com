---
import type { GetStaticPathsItem, GetStaticPathsResult } from "astro";
import type { CollectionEntry, CollectionKey } from "astro:content";

import { getViewPageProps } from "@server/api";
import { collections } from "@server/types";
import { getCollection, render } from "astro:content";

import LayoutRoot from "../../components/layout/layout-root.astro";
import NavigationProgress from "../../components/layout/navigation-progress.astro";

export const prerender = true;

type Props = CollectionEntry<CollectionKey>;

export async function getStaticPaths(): Promise<GetStaticPathsResult> {
  const result = await Promise.all(
    collections.map(async (collection): Promise<GetStaticPathsItem[]> => {
      const items = await getCollection(collection);

      return items.map((item): GetStaticPathsItem => {
        const { collection, id: slug } = item;
        return {
          params: { collection, slug },
          props: item,
        };
      });
    })
  );

  return result.flat();
}

const entry = Astro.props as Props;
const { collection } = Astro.params;

if (entry === undefined) {
  return Astro.redirect("/404");
}

const { Content } = await render(entry);
const viewProps = await getViewPageProps(entry as any);
---

<LayoutRoot
  description={viewProps.description ?? ""}
  slug={`/${collection}/${entry.id}`}
  title={viewProps.title}
>
  <NavigationProgress />

  <article class="container mx-auto max-w-4xl px-4 py-12 md:py-24">
    <header
      class="mb-12 flex animate-in flex-col gap-8 duration-700 fade-in slide-in-from-bottom-4"
    >
      <h1 class="text-4xl leading-tight font-bold tracking-tight lg:text-5xl">
        {viewProps.title}
      </h1>

      <div
        class="flex flex-wrap items-center gap-4 font-mono text-sm tracking-wider text-muted-foreground uppercase"
      >
        {
          Array.isArray(viewProps.tags) &&
            viewProps.tags.map((tag: string) => (
              <span class="rounded-md bg-secondary px-2 py-1 text-secondary-foreground">
                #{tag}
              </span>
            ))
        }
        {/* Date or other meta could go here if available in viewProps */}
      </div>

      {
        viewProps.description && (
          <p class="text-xl text-muted-foreground">{viewProps.description}</p>
        )
      }
    </header>

    <div
      class="prose prose-lg max-w-none dark:prose-invert prose-headings:font-bold prose-a:text-primary hover:prose-a:underline prose-img:rounded-xl"
    >
      <Content />
    </div>
  </article>
</LayoutRoot>

<script>
  import { initFocusMode } from "@client";

  const init = () => {
    initFocusMode();
  };

  init();
  document.addEventListener("astro:page-load", init);
</script>
