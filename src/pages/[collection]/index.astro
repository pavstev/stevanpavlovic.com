---
// Handles: /blog, /projects, /experience (defaults to list display, page 1)
import type { GetStaticPaths } from "astro";
import type { CollectionKey } from "astro:content";

import LayoutRoot from "../../components/layout/layout-root.astro";
import ResourceDiscovery from "../../components/organisms/resource-discovery.astro";
import { NAV_ITEMS } from "../../config";
import { type DisplayMode, getCollectionPageData } from "../../lib/content/api";

export const prerender = true;

export interface Params {
  collection: CollectionKey;
}

export const getStaticPaths: GetStaticPaths = async () => {
    const collections = Object.keys(NAV_ITEMS).filter((k) => k !== "home") as CollectionKey[];

    return collections.map((collection) => ({
        params: { collection },
    }));
};

const { collection } = Astro.params as unknown as Params;
const display = (Astro.url.searchParams.get("display") as DisplayMode) || "list";
const pageData = await getCollectionPageData(collection, 1, display);

const {
    baseUrl,
    collectionItems,
    config,
    containerId,
    currentPage,
    displayUrls,
    getItemCardProps,
    initialPageSize,
    nextUrl,
    prevUrl,
    totalItems,
    totalPages,
} = pageData;
---

<LayoutRoot description={config.description} slug={`/${collection}`} title={config.title}>
    <ResourceDiscovery
        {...config}
        baseUrl={baseUrl}
        collectionItems={collectionItems}
        collectionKey={collection}
        containerId={containerId}
        currentPage={currentPage}
        display={display}
        displayUrls={displayUrls}
        getItemCardProps={getItemCardProps}
        initialPageSize={initialPageSize}
        nextUrl={nextUrl}
        prevUrl={prevUrl}
        totalItems={totalItems}
        totalPages={totalPages}
    />
</LayoutRoot>
