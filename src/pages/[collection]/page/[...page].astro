---
// Handles: /blog/grid/2, /blog/list/3, etc. (explicit display, pages 2+)
import type { GetStaticPaths } from "astro";
import type { CollectionKey } from "astro:content";

import LayoutRoot from "../../../components/layout/layout-root.astro";
import ResourceDiscovery from "../../../components/organisms/ResourceDiscovery.astro";
import { ITEMS_PER_PAGE } from "../../../config";
import { collections } from "../../../content.config";
import { type DisplayMode, getCollectionData, getCollectionPageData } from "../../../lib";
import { type Params as BaseParams } from "./../[display].astro";

interface Params extends BaseParams {
  page: `${number}`;
}

export const prerender = true;

export const getStaticPaths: GetStaticPaths = async () => {
  const displays: DisplayMode[] = ["list", "grid"];
  const paths: Array<{
    params: {
      collection: CollectionKey;
      display: DisplayMode;
      page: string;
    };
  }> = [];

  const collectionNames = Object.keys(collections) as CollectionKey[];
  for (const collection of collectionNames) {
    const sortedItems = await getCollectionData(collection);
    const totalItems = sortedItems.length;
    const totalPages = Math.max(1, Math.ceil(totalItems / ITEMS_PER_PAGE));

    for (const display of displays) {
      // Start from page 2 since page 1 is handled by [display].astro
      for (let pageNum = 2; pageNum <= totalPages; pageNum++) {
        paths.push({
          params: {
            collection,
            display,
            page: String(pageNum),
          },
        });
      }
    }
  }

  return paths;
};

const { collection, display, page } = Astro.params as unknown as Params;
const pageData = await getCollectionPageData(collection, page, display);

const {
  baseUrl,
  collectionItems,
  config,
  containerId,
  currentPage,
  displayUrls,
  getItemCardProps,
  initialPageSize,
  nextUrl,
  prevUrl,
  totalItems,
  totalPages,
} = pageData;
---

<LayoutRoot description={config.description} slug={`/${collection}/${display}/${page}`} title={`${config.title} - Page ${page}`}>
  <ResourceDiscovery
    {...config}
    baseUrl={baseUrl}
    collectionItems={collectionItems}
    collectionKey={collection}
    containerId={containerId}
    currentPage={currentPage}
    display={display}
    displayUrls={displayUrls}
    getItemCardProps={getItemCardProps}
    initialPageSize={initialPageSize}
    nextUrl={nextUrl}
    prevUrl={prevUrl}
    totalItems={totalItems}
    totalPages={totalPages}
  />
</LayoutRoot>
