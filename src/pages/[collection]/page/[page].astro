---
// Handles: /blog/page/2, /projects/page/3, etc. (pages 2+)
import type { GetStaticPaths } from "astro";
import type { CollectionKey } from "astro:content";

import { type DisplayMode, getCollectionData, getCollectionPageData } from "@server/content/api";

import LayoutRoot from "../../../components/layout/layout-root.astro";
import ResourceDiscovery from "../../../components/organisms/resource-discovery.astro";
import { ITEMS_PER_PAGE } from "../../../config";
import { collections } from "../../../content.config";

export interface Params {
  collection: CollectionKey;
  page: string;
}

export const prerender = true;

export const getStaticPaths: GetStaticPaths = async () => {
  const paths: Array<{
    params: {
      collection: CollectionKey;
      page: string;
    };
  }> = [];

  const collectionNames = Object.keys(collections) as CollectionKey[];
  for (const collection of collectionNames) {
    const sortedItems = await getCollectionData(collection);
    const totalItems = sortedItems.length;
    const totalPages = Math.max(1, Math.ceil(totalItems / ITEMS_PER_PAGE));

    // Start from page 2 since page 1 is handled by index.astro
    for (let pageNum = 2; pageNum <= totalPages; pageNum++) {
      paths.push({
        params: {
          collection,
          page: String(pageNum),
        },
      });
    }
  }

  return paths;
};

const { collection, page } = Astro.params as unknown as Params;
const display = (Astro.url.searchParams.get("display") as DisplayMode) || "list";
const pageData = await getCollectionPageData(collection, page, display);

const {
  baseUrl,
  collectionItems,
  config,
  containerId,
  currentPage,
  displayUrls,
  getItemCardProps,
  initialPageSize,
  nextUrl,
  prevUrl,
  totalItems,
  totalPages,
} = pageData;
---

<LayoutRoot
  description={config.description}
  slug={`/${collection}/page/${page}`}
  title={`${config.title} - Page ${page}`}
>
  <ResourceDiscovery
    {...config}
    baseUrl={baseUrl}
    collectionItems={collectionItems}
    collectionKey={collection}
    containerId={containerId}
    currentPage={currentPage}
    display={display}
    displayUrls={displayUrls}
    getItemCardProps={getItemCardProps}
    initialPageSize={initialPageSize}
    nextUrl={nextUrl}
    prevUrl={prevUrl}
    totalItems={totalItems}
    totalPages={totalPages}
  />
</LayoutRoot>
