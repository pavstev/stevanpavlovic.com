---
import { getCollection } from "astro:content";

import Badge from "../components/atoms/Badge.astro";
import Heading from "../components/atoms/Heading.astro";
import Stack from "../components/atoms/Stack.astro";
import Text from "../components/atoms/Text.astro";
import LayoutRoot from "../components/layout/layout-root.astro";
import BrandIdentity from "../components/molecules/BrandIdentity.astro";
import GridTile from "../components/molecules/GridTile.astro";
import CompositionGrid from "../components/organisms/CompositionGrid.astro";
import ResourceDiscovery from "../components/organisms/ResourceDiscovery.astro";
import StatsGrid from "../components/organisms/stats-grid.astro";
import { PROFILE, STATS } from "../config";
import { getItemCardProps } from "../lib/content/api";

// 1. Data Orchestration: Fetch Featured Highlights
const featuredProjects = (await getCollection("projects")).filter((p) => p.data.featured).slice(0, 3);
---

<LayoutRoot description={PROFILE.bio} slug="/" title={`${PROFILE.name} | Software Architect`}>
  <CompositionGrid class="relative z-10 py-12 md:py-24">
    {/* PHASE 1: THE SIGNATURE SECTION */}
    <GridTile class="overflow-hidden p-8 md:p-16" cols="lg:col-span-12">
      <div class="relative z-10 flex flex-col gap-10">
        {/* Live Status HUD */}
        <div class="animate-in fade-in slide-in-from-left-4 flex items-center gap-4 duration-700">
          <BrandIdentity size="xs" variant="status">
            <span class="text-[10px] font-bold tracking-[0.2em] text-accent/80 uppercase">
              {PROFILE.status}
            </span>
          </BrandIdentity>
          <div class="h-px w-12 bg-white/10"></div>
          <Badge variant="outline">{PROFILE.location}</Badge>
        </div>

        {/* Brand Core */}
        <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
          <div class="flex max-w-3xl flex-col gap-4">
            <BrandIdentity class="mb-4" size="lg" variant="author" />
            <Heading class="leading-[1.1] tracking-tight" level={1} size="display" variant="primary">
              Architecting <span class="text-white">Resilient</span>
              <br />
              Distributed Systems.
            </Heading>
            <Text class="max-w-2xl text-lg leading-relaxed text-muted-foreground/90 md:text-xl">
              {PROFILE.bio}
            </Text>
          </div>
        </div>

        {/* Global Impact Metrics */}
        <div class="border-t border-white/5 pt-6">
          <StatsGrid items={STATS} />
        </div>
      </div>

      {/* Decorative Brand Accent */}
      <div class="pointer-events-none absolute -right-20 -bottom-20 size-96 rounded-full bg-primary/5 blur-[120px]">
      </div>
    </GridTile>

    {/* PHASE 2: DYNAMIC HIGHLIGHTS ENGINE */}
    <div class="lg:col-span-12">
      <ResourceDiscovery
        baseUrl="/projects"
        collectionItems={featuredProjects as any}
        collectionKey="projects"
        containerId="featured-projects"
        description="Featured Highlights"
        display="grid"
        getItemCardProps={getItemCardProps as any}
        headerDescription="Hand-picked projects that demonstrate technical depth and architectural vision."
        headerIcon="mdi:star-outline"
        headerTitle="Featured Highlights"
        initialPageSize={3}
        title="Featured Highlights"
        totalItems={featuredProjects.length}
      />
    </div>

    {/* PHASE 3: THE ECOSYSTEM NAVIGATOR */}
    <GridTile class="border-primary/10 bg-primary/5 p-8 lg:col-span-12">
      <div class="flex flex-col items-center justify-between gap-8 md:flex-row">
        <Stack gap={2}>
          <Heading level={3} size="md">Ready to build something extraordinary?</Heading>
          <Text variant="muted">Explore my full repository of projects and technical writing.</Text>
        </Stack>
        <div class="flex gap-4">
          <a
            class="hover:shadow-glow-primary rounded-full bg-primary px-6 py-3 font-bold text-white transition-all"
            href="/projects">Browse Projects</a
          >
          <a
            class="rounded-full border border-white/10 bg-white/5 px-6 py-3 font-bold text-white transition-all hover:bg-white/10"
            href="/blog">Read Blog</a
          >
        </div>
      </div>
    </GridTile>
  </CompositionGrid>
</LayoutRoot>

<style>
  /* High-Performance Micro-Animations */
  @starting-style {
    .animate-in {
      opacity: 0;
      transform: translateY(10px);
    }
  }
</style>
