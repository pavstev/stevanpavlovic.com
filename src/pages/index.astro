---
import { getCollection } from "astro:content";

import LayoutRoot from "../components/layout/layout-root.astro";
import { PROFILE } from "../config";

// 1. Data Orchestration: Fetch Featured Highlights
const featuredProjects = (await getCollection("projects"))
  .filter((p) => p.data.featured)
  .slice(0, 3);
---

<LayoutRoot description={PROFILE.bio} slug="/" title={PROFILE.name}>
  <div class="relative z-10 container mx-auto px-4 py-12 md:py-24">
    <section class="py-20">
      <h1 class="text-4xl font-bold">Hero Section</h1>
      <p>Placeholder for Hero content (previously HeroSection)</p>
    </section>

    <section class="py-20">
      <h2 class="text-3xl font-bold">Featured Projects</h2>
      <div class="mt-8 grid grid-cols-1 gap-6 md:grid-cols-3">
        {
          featuredProjects.map((p) => (
            <div class="rounded-lg border p-4">
              <h3 class="font-bold">{p.data.title}</h3>
              <p>{p.data.description}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="py-20">
      <h2 class="text-3xl font-bold">Get In Touch</h2>
      <p>Placeholder for CTA (previously CTASection)</p>
    </section>
  </div>
</LayoutRoot>
