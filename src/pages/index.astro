---
import { getCollection } from "astro:content";

import Container from "../components/atoms/container.astro";
import LayoutRoot from "../components/layout/layout-root.astro";
import CTASection from "../components/sections/cta-section.astro";
import FeaturedHighlights from "../components/sections/featured-highlights.astro";
import HeroSection from "../components/sections/hero-section.astro";
import { PROFILE } from "../config";

// 1. Data Orchestration: Fetch Featured Highlights
const featuredProjects = (await getCollection("projects"))
  .filter((p) => p.data.featured)
  .slice(0, 3);
---

<LayoutRoot description={PROFILE.bio} slug="/" title={PROFILE.name}>
  <Container class="relative z-10 py-12 md:py-24">
    <HeroSection />
    <FeaturedHighlights projects={featuredProjects} />
    <CTASection />
  </Container>
</LayoutRoot>
