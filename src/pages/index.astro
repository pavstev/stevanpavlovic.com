---
import { getCollection } from "astro:content";

import BentoGrid, { type BentoItem } from "../components/kokonutui/bento-grid";
import LayoutRoot from "../components/layout/layout-root.astro";
import { BackgroundPaths } from "../components/ui/background-paths";
import { PROFILE } from "../config";

const featuredProjects = await getCollection("projects", ({ data }) => data.featured);
const latestBlog = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const experience = (await getCollection("experience")).sort(
  (a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf()
);

const bentoItems: BentoItem[] = [
  // Item 0: Expertise & Stack (Small slot)
  {
    className: "col-span-1",
    description:
      "Architecting scalable backend systems with Node.js, Go, and Cloud-native technologies.",
    feature: "icons",
    href: "/about",
    id: "expertise",
    title: "Expertise",
  },
  // Item 1: Selected Works (Large slot)
  {
    className: "col-span-2",
    description:
      "A showcase of enterprise-grade applications, AI agents, and high-performance platforms.",
    feature: "spotlight",
    href: "/projects",
    id: "works",
    spotlightItems: featuredProjects.slice(0, 5).map((p) => p.data.title),
    title: "Selected Works",
  },
  // Item 2: Career Journey (Bottom row, Left)
  {
    className: "col-span-1",
    description: "Lead Backend Developer & System Architect with 10+ years of experience.",
    feature: "timeline",
    href: "/experience",
    id: "journey",
    timeline: experience.slice(0, 5).map((exp) => ({
      event: exp.data.role,
      year: exp.data.startDate.getFullYear().toString(),
    })),
    title: "Professional Journey",
  },
  // Item 3: Insights & Thoughts (Bottom row, Right)
  {
    className: "col-span-1",
    description: "Diving deep into software architecture, devops, and the future of AI.",
    feature: "typing",
    href: "/blog",
    id: "insights",
    title: "Latest Insights",
    typingText: `// Latest Post: ${latestBlog[0]?.data.title || "Exploring Architecture"}\n\nprintf("Hello world! Reading: %s", blogTitle);`,
  },
];
---

<LayoutRoot description={PROFILE.bio} isFullWidth={true} slug="/" title={PROFILE.name}>
  <BackgroundPaths client:load title={PROFILE.name} />

  <BentoGrid client:load items={bentoItems} />

  <div class="container mx-auto px-4 py-12 md:py-24">
    <section class="py-20">
      <h2 class="text-3xl font-bold">Get In Touch</h2>
      <p>Placeholder for CTA (previously CTASection)</p>
    </section>
  </div>
</LayoutRoot>
