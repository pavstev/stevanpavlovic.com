---
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";

import BentoGrid, { type BentoItem } from "../components/kokonutui/bento-grid";
import LayoutRoot from "../components/layout/layout-root.astro";
import { BackgroundPaths } from "../components/ui/background-paths";
import { Button } from "../components/ui/button";
import { Card, CardContent } from "../components/ui/card";
import { Input } from "../components/ui/input";
import { Label } from "../components/ui/label";
import { Textarea } from "../components/ui/textarea";
import { PROFILE, SOCIALS } from "../config";

const featuredProjects = await getCollection("projects", ({ data }) => data.featured);
const latestBlog = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const experience = (await getCollection("experience")).sort(
  (a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf()
);

const bentoItems: BentoItem[] = [
  // Item 0: Expertise & Stack (Small slot)
  {
    className: "col-span-1",
    description:
      "Architecting scalable backend systems with Node.js, Go, and Cloud-native technologies.",
    feature: "icons",
    href: "/about",
    id: "expertise",
    title: "Expertise",
  },
  // Item 1: Selected Works (Large slot)
  {
    className: "col-span-2",
    description:
      "A showcase of enterprise-grade applications, AI agents, and high-performance platforms.",
    feature: "spotlight",
    href: "/projects",
    id: "works",
    spotlightItems: featuredProjects.slice(0, 5).map((p) => p.data.title),
    title: "Selected Works",
  },
  // Item 2: Career Journey (Bottom row, Left)
  {
    className: "col-span-1",
    description: "Lead Backend Developer & System Architect with 10+ years of experience.",
    feature: "timeline",
    href: "/experience",
    id: "journey",
    timeline: experience.slice(0, 5).map((exp) => ({
      event: exp.data.role,
      year: exp.data.startDate.getFullYear().toString(),
    })),
    title: "Professional Journey",
  },
  // Item 3: Insights & Thoughts (Bottom row, Right)
  {
    className: "col-span-1",
    description: "Diving deep into software architecture, devops, and the future of AI.",
    feature: "typing",
    href: "/blog",
    id: "insights",
    title: "Latest Insights",
    typingText: `// Latest Post: ${latestBlog[0]?.data.title || "Exploring Architecture"}\n\nprintf("Hello world! Reading: %s", blogTitle);`,
  },
];
---

<LayoutRoot description={PROFILE.bio} isFullWidth={true} slug="/" title={PROFILE.name}>
  <BackgroundPaths client:load title={PROFILE.name} />

  <BentoGrid client:load items={bentoItems} />

  <div class="container mx-auto px-4 py-12 md:py-24">
    <section class="mx-auto max-w-4xl py-24">
      <Card className="overflow-hidden border-0 bg-card p-1 shadow-2xl">
        <CardContent className="grid grid-cols-1 gap-8 bg-background/50 p-8 md:grid-cols-2 md:p-12">
          <div class="flex flex-col justify-between gap-6">
            <div class="space-y-4">
              <h2 class="text-3xl font-bold tracking-tight">Get In Touch</h2>
              <p class="text-muted-foreground">
                Have a project in mind or just want to chat? I'm always open to discussing new ideas
                and opportunities.
              </p>
            </div>

            {
              SOCIALS.map((social) => (
                <div class="flex items-center gap-3">
                  <span class="flex size-10 items-center justify-center rounded-full bg-primary/10 text-primary">
                    {social.name === "GitHub" && <Icon class="size-5" name="mdi:github" />}
                    {social.name === "LinkedIn" && <Icon class="size-5" name="mdi:linkedin" />}
                    {social.name === "Email" && <Icon class="size-5" name="mdi:email" />}
                  </span>
                  <a
                    class="text-sm font-medium hover:text-primary"
                    href={social.href}
                    rel="noreferrer"
                    target="_blank"
                  >
                    {social.name === "Email" ? social.handle : `${social.name} Profile`}
                  </a>
                </div>
              ))
            }
          </div>

          <form class="space-y-4">
            <div class="grid grid-cols-2 gap-4">
              <div class="space-y-2">
                <Label client:load htmlFor="name">Name</Label>
                <Input client:load id="name" placeholder="John Doe" required />
              </div>
              <div class="space-y-2">
                <Label client:load htmlFor="email">Email</Label>
                <Input
                  client:load
                  id="email"
                  placeholder="john@example.com"
                  required
                  type="email"
                />
              </div>
            </div>
            <div class="space-y-2">
              <Label client:load htmlFor="subject">Subject</Label>
              <Input client:load id="subject" placeholder="Project Inquiry" required />
            </div>
            <div class="space-y-2">
              <Label client:load htmlFor="message">Message</Label>
              <Textarea
                className="min-h-[120px]"
                client:load
                id="message"
                placeholder="Tell me about your project..."
                required
              />
            </div>
            <Button className="w-full" client:load size="lg" type="submit"> Send Message </Button>
          </form>
        </CardContent>
      </Card>
    </section>
  </div>
</LayoutRoot>
