---
import Badge from "../../components/atoms/Badge.astro";
import Container from "../../components/atoms/Container.astro";
import Heading from "../../components/atoms/Heading.astro";
import Stack from "../../components/atoms/Stack.astro";
import Text from "../../components/atoms/Text.astro";
---

<Container>
  <Stack gap={6}>
    <Stack align="center" gap={4}>
      <Heading level={1} size="lg" variant="primary">
        Avatar
      </Heading>
      <Text class="max-w-2xl text-center" size="lg" variant="muted">
        Displays user profile images or fallback initials with various sizes and variants.
      </Text>
      <Badge variant="cyber">Atoms</Badge>
    </Stack>

    <Separator />

    <!-- Sizes -->
    <Stack gap={4}>
      <Heading level={2} size="md" variant="accent">
        Sizes
      </Heading>
      <Text variant="muted">
        Five size options from extra small to extra large.
      </Text>

      <Stack align="center" gap={2}>
        <div class="flex items-end gap-4">
          <Stack align="center" gap={2}>
            <div class="relative flex size-6 shrink-0 overflow-hidden rounded-full border border-border/50 bg-muted/20">
              <div class="flex size-full items-center justify-center bg-muted font-medium text-muted-foreground uppercase">
                <span class="text-[10px] select-none">XS</span>
              </div>
            </div>
            <Text size="xs" variant="muted">6px</Text>
          </Stack>

          <Stack align="center" gap={2}>
            <div class="relative flex size-8 shrink-0 overflow-hidden rounded-full border border-border/50 bg-muted/20">
              <div class="flex size-full items-center justify-center bg-muted font-medium text-muted-foreground uppercase">
                <span class="text-xs select-none">SM</span>
              </div>
            </div>
            <Text size="xs" variant="muted">8px</Text>
          </Stack>

          <Stack align="center" gap={2}>
            <div class="relative flex size-10 shrink-0 overflow-hidden rounded-full border border-border/50 bg-muted/20">
              <div class="flex size-full items-center justify-center bg-muted font-medium text-muted-foreground uppercase">
                <span class="text-sm select-none">MD</span>
              </div>
            </div>
            <Text size="xs" variant="muted">10px</Text>
          </Stack>

          <Stack align="center" gap={2}>
            <div class="relative flex size-12 shrink-0 overflow-hidden rounded-full border border-border/50 bg-muted/20">
              <div class="flex size-full items-center justify-center bg-muted font-medium text-muted-foreground uppercase">
                <span class="text-base select-none">LG</span>
              </div>
            </div>
            <Text size="xs" variant="muted">12px</Text>
          </Stack>

          <Stack align="center" gap={2}>
            <div class="relative flex size-16 shrink-0 overflow-hidden rounded-full border border-border/50 bg-muted/20">
              <div class="flex size-full items-center justify-center bg-muted font-medium text-muted-foreground uppercase">
                <span class="text-xl select-none">XL</span>
              </div>
            </div>
            <Text size="xs" variant="muted">16px</Text>
          </Stack>
        </div>
      </Stack>
    </Stack>

    <!-- Variants -->
    <Stack gap={4}>
      <Heading level={2} size="md" variant="accent">
        Variants
      </Heading>

      <Stack direction="row" gap={3} wrap="wrap">
        <Stack align="center" gap={2}>
          <div class="relative flex size-12 shrink-0 overflow-hidden rounded-full border border-border/50 bg-muted/20">
            <div class="flex size-full items-center justify-center bg-muted font-medium text-muted-foreground uppercase">
              <span class="text-sm select-none">DF</span>
            </div>
          </div>
          <Text size="xs" variant="muted">Default</Text>
        </Stack>

        <Stack align="center" gap={2}>
          <div class="glass relative flex size-12 shrink-0 overflow-hidden rounded-full border-white/10 bg-white/5">
            <div class="flex size-full items-center justify-center bg-muted font-medium text-muted-foreground uppercase">
              <span class="text-sm select-none">GL</span>
            </div>
          </div>
          <Text size="xs" variant="muted">Glass</Text>
        </Stack>

        <Stack align="center" gap={2}>
          <div class="shadow-glow-primary relative flex size-12 shrink-0 overflow-hidden rounded-full border border-primary/30 bg-primary/10">
            <div class="flex size-full items-center justify-center bg-primary/20 font-medium text-primary uppercase">
              <span class="text-sm select-none">PR</span>
            </div>
          </div>
          <Text size="xs" variant="muted">Primary</Text>
        </Stack>
      </Stack>
    </Stack>

    <!-- With Images -->
    <Stack gap={4}>
      <Heading level={2} size="md" variant="accent">
        With Images
      </Heading>

      <Stack direction="row" gap={3} wrap="wrap">
        <Stack align="center" gap={2}>
          <div class="relative flex size-16 shrink-0 overflow-hidden rounded-full border border-border/50 bg-muted/20">
            <img alt="User" class="aspect-square size-full object-cover" src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=100&h=100&fit=crop&crop=face" />
          </div>
          <Text size="xs" variant="muted">Default</Text>
        </Stack>

        <Stack align="center" gap={2}>
          <div class="glass relative flex size-16 shrink-0 overflow-hidden rounded-full border-white/10 bg-white/5">
            <img alt="User" class="aspect-square size-full object-cover" src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&h=100&fit=crop&crop=face" />
          </div>
          <Text size="xs" variant="muted">Glass</Text>
        </Stack>

        <Stack align="center" gap={2}>
          <div class="shadow-glow-primary relative flex size-16 shrink-0 overflow-hidden rounded-full border border-primary/30 bg-primary/10">
            <img alt="User" class="aspect-square size-full object-cover" src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=100&h=100&fit=crop&crop=face" />
          </div>
          <Text size="xs" variant="muted">Primary</Text>
        </Stack>
      </Stack>
    </Stack>

    <!-- Avatar Group -->
    <Stack gap={4}>
      <Heading level={2} size="md" variant="accent">
        Avatar Group
      </Heading>

      <div class="flex -space-x-3">
        <div class="shadow-glow-subtle relative flex size-12 shrink-0 overflow-hidden rounded-full border-2 border-card ring-2 ring-background transition-all duration-300">
          <div class="flex size-full items-center justify-center bg-primary/20 font-medium text-primary uppercase">
            <span class="text-sm select-none">A</span>
          </div>
        </div>
        <div class="shadow-glow-subtle relative flex size-12 shrink-0 overflow-hidden rounded-full border-2 border-card ring-2 ring-background transition-all duration-300">
          <div class="flex size-full items-center justify-center bg-secondary/20 font-medium text-secondary uppercase">
            <span class="text-sm select-none">B</span>
          </div>
        </div>
        <div class="shadow-glow-subtle relative flex size-12 shrink-0 overflow-hidden rounded-full border-2 border-card ring-2 ring-background transition-all duration-300">
          <div class="flex size-full items-center justify-center bg-accent/20 font-medium text-accent uppercase">
            <span class="text-sm select-none">C</span>
          </div>
        </div>
        <div class="shadow-glow-subtle relative flex size-12 shrink-0 overflow-hidden rounded-full border-2 border-card ring-2 ring-background transition-all duration-300">
          <img alt="User" class="aspect-square size-full object-cover" src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&h=100&fit=crop&crop=face" />
        </div>
        <div class="shadow-glow-subtle relative flex size-12 shrink-0 overflow-hidden rounded-full border-2 border-card bg-muted/50 ring-2 ring-background transition-all duration-300">
          <div class="flex size-full items-center justify-center bg-muted font-medium text-muted-foreground uppercase">
            <span class="text-sm select-none">+3</span>
          </div>
        </div>
      </div>
    </Stack>
  </Stack>
</Container>
