---
import Badge from "../../components/atoms/Badge.astro";
import Container from "../../components/atoms/Container.astro";
import Heading from "../../components/atoms/Heading.astro";
import Icon from "../../components/atoms/Icon.astro";
import Separator from "../../components/atoms/Separator.astro";
import Stack from "../../components/atoms/Stack.astro";
import Text from "../../components/atoms/Text.astro";
---

<Container>
  <Stack gap={6}>
    <!-- Header -->
    <Stack align="center" gap={4}>
      <Heading level={1} size="display" variant="primary">
        Design System
      </Heading>
      <Text size="lg" variant="muted">
        A showcase of all atom components in the SPCOM design system
      </Text>
      <Badge variant="cyber">v1.0.0</Badge>
    </Stack>

    <Separator />

    <!-- Avatar Section -->
    <Stack gap={4}>
      <Heading level={2} size="lg" variant="accent">
        Avatar
      </Heading>
      <Text variant="muted">
        Displays user profile images or fallback initials with various sizes and variants.
      </Text>

      <Stack direction="row" gap={4} wrap="wrap">
        <!-- Default -->
        <Stack align="center" gap={2}>
          <div class="relative flex size-10 shrink-0 overflow-hidden rounded-full border border-border/50 bg-muted/20">
            <div class="flex size-full items-center justify-center bg-muted font-medium text-muted-foreground uppercase">
              <span class="text-sm select-none">JD</span>
            </div>
          </div>
          <Text size="sm" variant="muted">Default</Text>
        </Stack>

        <!-- Glass -->
        <Stack align="center" gap={2}>
          <div class="glass relative flex size-10 shrink-0 overflow-hidden rounded-full border-white/10 bg-white/5">
            <div class="flex size-full items-center justify-center bg-muted font-medium text-muted-foreground uppercase">
              <span class="text-sm select-none">GL</span>
            </div>
          </div>
          <Text size="sm" variant="muted">Glass</Text>
        </Stack>

        <!-- Primary -->
        <Stack align="center" gap={2}>
          <div class="shadow-glow-primary relative flex size-10 shrink-0 overflow-hidden rounded-full border border-primary/30 bg-primary/10">
            <div class="flex size-full items-center justify-center bg-primary/20 font-medium text-primary uppercase">
              <span class="text-sm select-none">PR</span>
            </div>
          </div>
          <Text size="sm" variant="muted">Primary</Text>
        </Stack>

        <!-- Sizes -->
        <Stack align="center" gap={2}>
          <div class="flex items-end gap-2">
            <div class="relative flex size-6 shrink-0 overflow-hidden rounded-full border border-border/50 bg-muted/20">
              <div class="flex size-full items-center justify-center bg-muted font-medium text-muted-foreground uppercase">
                <span class="text-[10px] select-none">XS</span>
              </div>
            </div>
            <div class="relative flex size-8 shrink-0 overflow-hidden rounded-full border border-border/50 bg-muted/20">
              <div class="flex size-full items-center justify-center bg-muted font-medium text-muted-foreground uppercase">
                <span class="text-xs select-none">SM</span>
              </div>
            </div>
            <div class="relative flex size-10 shrink-0 overflow-hidden rounded-full border border-border/50 bg-muted/20">
              <div class="flex size-full items-center justify-center bg-muted font-medium text-muted-foreground uppercase">
                <span class="text-sm select-none">MD</span>
              </div>
            </div>
            <div class="relative flex size-12 shrink-0 overflow-hidden rounded-full border border-border/50 bg-muted/20">
              <div class="flex size-full items-center justify-center bg-muted font-medium text-muted-foreground uppercase">
                <span class="text-base select-none">LG</span>
              </div>
            </div>
            <div class="relative flex size-16 shrink-0 overflow-hidden rounded-full border border-border/50 bg-muted/20">
              <div class="flex size-full items-center justify-center bg-muted font-medium text-muted-foreground uppercase">
                <span class="text-xl select-none">XL</span>
              </div>
            </div>
          </div>
          <Text size="sm" variant="muted">Sizes</Text>
        </Stack>
      </Stack>
    </Stack>

    <Separator />

    <!-- Badge Section -->
    <Stack gap={4}>
      <Heading level={2} size="lg" variant="accent">
        Badge
      </Heading>
      <Text variant="muted">
        Small labels for status, categories, or notifications.
      </Text>

      <Stack direction="row" gap={3} wrap="wrap">
        <span class="inline-flex items-center rounded-full border border-border/50 bg-foreground/5 px-2 py-0.5 font-mono text-[10px] font-bold tracking-widest text-muted-foreground uppercase transition-all duration-300 select-none hover:border-primary/30">
          DEFAULT
        </span>
        <span class="shadow-glow-primary inline-flex items-center rounded-full border border-primary/40 bg-primary/10 px-2 py-0.5 font-mono text-[10px] font-bold tracking-widest text-primary uppercase transition-all duration-300 select-none">
          PRIMARY
        </span>
        <span class="shadow-glow-accent inline-flex items-center rounded-full border border-accent/40 bg-accent/10 px-2 py-0.5 font-mono text-[10px] font-bold tracking-widest text-accent uppercase transition-all duration-300 select-none">
          ACCENT
        </span>
        <span class="neon-border inline-flex items-center rounded-full border bg-card/80 px-2.5 py-0.5 font-mono text-[10px] font-bold tracking-widest text-foreground uppercase transition-all duration-300 select-none">
          CYBER
        </span>
      </Stack>

      <!-- Tech Stack Badges -->
      <Heading level={3} size="sm" variant="default">
        Tech Stack
      </Heading>
      <Stack direction="row" gap={2} wrap="wrap">
        <span class="neon-border inline-flex items-center rounded-full border bg-card/80 px-2.5 py-0.5 font-mono text-[10px] font-bold tracking-widest text-foreground uppercase transition-all duration-300 select-none">
          ASTRO
        </span>
        <span class="shadow-glow-primary inline-flex items-center rounded-full border border-primary/40 bg-primary/10 px-2.5 py-0.5 font-mono text-[10px] font-bold tracking-widest text-primary uppercase transition-all duration-300 select-none">
          TAILWIND
        </span>
        <span class="shadow-glow-accent inline-flex items-center rounded-full border border-accent/40 bg-accent/10 px-2.5 py-0.5 font-mono text-[10px] font-bold tracking-widest text-accent uppercase transition-all duration-300 select-none">
          TYPESCRIPT
        </span>
        <span class="inline-flex items-center rounded-full border border-border/50 bg-foreground/5 px-2 py-0.5 font-mono text-[10px] font-bold tracking-widest text-muted-foreground uppercase transition-all duration-300 select-none hover:border-primary/30">
          NODE
        </span>
      </Stack>

      <!-- Status Badges -->
      <Heading level={3} size="sm" variant="default">
        Status
      </Heading>
      <Stack direction="row" gap={2} wrap="wrap">
        <span class="neon-border inline-flex items-center rounded-full border bg-card/80 px-2.5 py-0.5 font-mono text-[10px] font-bold tracking-widest text-foreground uppercase transition-all duration-300 select-none">
          NEW
        </span>
        <span class="shadow-glow-primary inline-flex items-center rounded-full border border-primary/40 bg-primary/10 px-2 py-0.5 font-mono text-[10px] font-bold tracking-widest text-primary uppercase transition-all duration-300 select-none">
          FEATURED
        </span>
        <span class="shadow-glow-accent inline-flex items-center rounded-full border border-accent/40 bg-accent/10 px-2 py-0.5 font-mono text-[10px] font-bold tracking-widest text-accent uppercase transition-all duration-300 select-none">
          LIVE
        </span>
        <span class="inline-flex items-center rounded-full border border-border/50 bg-foreground/5 px-2 py-0.5 font-mono text-[10px] font-bold tracking-widest text-muted-foreground uppercase transition-all duration-300 select-none hover:border-primary/30">
          DRAFT
        </span>
      </Stack>
    </Stack>

    <Separator />

    <!-- Button Section -->
    <Stack gap={4}>
      <Heading level={2} size="lg" variant="accent">
        Button
      </Heading>
      <Text variant="muted">
        Interactive button component with multiple variants and sizes.
      </Text>

      <!-- Variants -->
      <Heading level={3} size="sm" variant="default">
        Variants
      </Heading>
      <Stack direction="row" gap={3} wrap="wrap">
        <button class="shadow-glow-primary relative inline-flex h-9 cursor-pointer items-center justify-center gap-2 rounded-lg border border-primary/50 bg-linear-to-b from-primary to-primary/80 px-4 text-[13px] font-medium tracking-wide whitespace-nowrap text-primary-foreground ring-offset-background transition-all duration-300 select-none hover:-translate-y-0.5 hover:shadow-[0_0_30px_hsl(210_100%_45%_/_0.6)] hover:brightness-110 focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:outline-none active:scale-[0.98]">
          Primary
        </button>
        <button class="shadow-glow-secondary hover:shadow-glow-secondary/80 inline-flex h-9 cursor-pointer items-center justify-center gap-2 rounded-lg bg-secondary px-4 text-[13px] font-medium tracking-wide whitespace-nowrap text-secondary-foreground ring-offset-background transition-all duration-300 select-none hover:bg-secondary/80 focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:outline-none active:scale-[0.98]">
          Secondary
        </button>
        <button class="hover:shadow-glow-primary inline-flex h-9 cursor-pointer items-center justify-center gap-2 rounded-lg border border-border bg-transparent px-4 text-[13px] font-medium tracking-wide whitespace-nowrap text-foreground ring-offset-background transition-all duration-300 select-none hover:border-primary/50 hover:bg-primary/5 hover:text-primary focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:outline-none active:scale-[0.98]">
          Outline
        </button>
        <button class="hover:shadow-glow-subtle inline-flex h-9 cursor-pointer items-center justify-center gap-2 rounded-lg px-4 text-[13px] font-medium tracking-wide whitespace-nowrap text-muted-foreground ring-offset-background transition-all duration-300 select-none hover:bg-foreground/5 hover:text-foreground focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:outline-none active:scale-[0.98]">
          Ghost
        </button>
        <button class="glass hover:shadow-glow inline-flex h-9 cursor-pointer items-center justify-center gap-2 rounded-lg border-white/10 px-4 text-[13px] font-medium tracking-wide whitespace-nowrap text-foreground shadow-sm ring-offset-background transition-all duration-300 select-none hover:-translate-y-0.5 hover:border-white/20 hover:bg-white/10 focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:outline-none active:scale-[0.98]">
          Glass
        </button>
        <button class="shadow-glow-destructive hover:shadow-glow-destructive/80 inline-flex h-9 cursor-pointer items-center justify-center gap-2 rounded-lg bg-destructive px-4 text-[13px] font-medium tracking-wide whitespace-nowrap text-destructive-foreground ring-offset-background transition-all duration-300 select-none hover:bg-destructive/90 focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:outline-none active:scale-[0.98]">
          Destructive
        </button>
      </Stack>

      <!-- Sizes -->
      <Heading level={3} size="sm" variant="default">
        Sizes
      </Heading>
      <Stack align="center" direction="row" gap={3} wrap="wrap">
        <button class="shadow-glow-primary relative inline-flex h-8 cursor-pointer items-center justify-center gap-2 rounded-md border border-primary/50 bg-linear-to-b from-primary to-primary/80 px-3 text-[12px] font-medium tracking-wide whitespace-nowrap text-primary-foreground ring-offset-background transition-all duration-300 select-none hover:-translate-y-0.5 hover:shadow-[0_0_30px_hsl(210_100%_45%_/_0.6)] hover:brightness-110 focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:outline-none active:scale-[0.98]">
          Small
        </button>
        <button class="shadow-glow-primary relative inline-flex h-9 cursor-pointer items-center justify-center gap-2 rounded-lg border border-primary/50 bg-linear-to-b from-primary to-primary/80 px-4 text-[13px] font-medium tracking-wide whitespace-nowrap text-primary-foreground ring-offset-background transition-all duration-300 select-none hover:-translate-y-0.5 hover:shadow-[0_0_30px_hsl(210_100%_45%_/_0.6)] hover:brightness-110 focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:outline-none active:scale-[0.98]">
          Medium
        </button>
        <button class="shadow-glow-primary relative inline-flex h-11 cursor-pointer items-center justify-center gap-2 rounded-xl border border-primary/50 bg-linear-to-b from-primary to-primary/80 px-6 text-[15px] font-medium tracking-wide whitespace-nowrap text-primary-foreground ring-offset-background transition-all duration-300 select-none hover:-translate-y-0.5 hover:shadow-[0_0_30px_hsl(210_100%_45%_/_0.6)] hover:brightness-110 focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:outline-none active:scale-[0.98]">
          Large
        </button>
        <button class="shadow-glow-primary relative inline-flex size-9 cursor-pointer items-center justify-center gap-2 rounded-full border border-primary/50 bg-linear-to-b from-primary to-primary/80 font-medium tracking-wide whitespace-nowrap text-primary-foreground ring-offset-background transition-all duration-300 select-none hover:-translate-y-0.5 hover:shadow-[0_0_30px_hsl(210_100%_45%_/_0.6)] hover:brightness-110 focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:outline-none active:scale-[0.98]">
          <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M12 4v16m8-8H4" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
          </svg>
        </button>
      </Stack>
    </Stack>

    <Separator />

    <!-- Icon Section -->
    <Stack gap={4}>
      <Heading level={2} size="lg" variant="accent">
        Icon
      </Heading>
      <Text variant="muted">
        Versatile icon component with multiple sizes and visual variants.
      </Text>

      <!-- Sizes -->
      <Heading level={3} size="sm" variant="default">
        Sizes
      </Heading>
      <Stack align="center" direction="row" gap={4} wrap="wrap">
        <Stack align="center" gap={2}>
          <svg class="size-3.5 shrink-0 text-current transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
          </svg>
          <Text size="xs" variant="muted">sm</Text>
        </Stack>
        <Stack align="center" gap={2}>
          <svg class="size-5 shrink-0 text-current transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
          </svg>
          <Text size="xs" variant="muted">md</Text>
        </Stack>
        <Stack align="center" gap={2}>
          <svg class="size-6 shrink-0 text-current transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
          </svg>
          <Text size="xs" variant="muted">lg</Text>
        </Stack>
        <Stack align="center" gap={2}>
          <svg class="size-7 shrink-0 text-current transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
          </svg>
          <Text size="xs" variant="muted">xl</Text>
        </Stack>
      </Stack>

      <!-- Variants -->
      <Heading level={3} size="sm" variant="default">
        Variants
      </Heading>
      <Stack align="center" direction="row" gap={4} wrap="wrap">
        <Stack align="center" gap={2}>
          <svg class="size-6 shrink-0 text-current transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
          </svg>
          <Text size="xs" variant="muted">default</Text>
        </Stack>
        <Stack align="center" gap={2}>
          <svg class="size-6 shrink-0 text-muted-foreground transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
          </svg>
          <Text size="xs" variant="muted">muted</Text>
        </Stack>
        <Stack align="center" gap={2}>
          <svg class="size-6 shrink-0 text-primary drop-shadow-[0_0_10px_rgba(59,130,246,0.5)] filter transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
          </svg>
          <Text size="xs" variant="muted">primary</Text>
        </Stack>
        <Stack align="center" gap={2}>
          <svg class="size-6 shrink-0 text-accent drop-shadow-[0_0_10px_rgba(74,222,128,0.5)] filter transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
          </svg>
          <Text size="xs" variant="muted">accent</Text>
        </Stack>
        <Stack align="center" gap={2}>
          <svg class="size-6 shrink-0 text-foreground drop-shadow-[0_0_10px_rgba(255,255,255,0.5)] filter transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
          </svg>
          <Text size="xs" variant="muted">glow</Text>
        </Stack>
      </Stack>
    </Stack>

    <Separator />

    <!-- Typography Section -->
    <Stack gap={4}>
      <Heading level={2} size="lg" variant="accent">
        Typography
      </Heading>
      <Text variant="muted">
        Text and heading components for consistent typography.
      </Text>

      <!-- Heading Sizes -->
      <Heading level={3} size="sm" variant="default">
        Heading Sizes
      </Heading>
      <Stack gap={3}>
        <h1 class="font-display text-[clamp(2.5rem,8vw,4.5rem)] leading-[0.9] font-black tracking-tight tracking-tighter text-foreground uppercase selection:bg-primary/30">
          Display Heading
        </h1>
        <h2 class="font-display text-[clamp(2rem,6vw,3.25rem)] leading-none font-black tracking-tight tracking-tighter text-foreground uppercase selection:bg-primary/30">
          Large Heading
        </h2>
        <h3 class="font-display text-[clamp(1.5rem,4vw,2.25rem)] font-bold tracking-tight text-foreground selection:bg-primary/30">
          Medium Heading
        </h3>
        <h4 class="font-display text-lg font-bold tracking-tight text-foreground selection:bg-primary/30 sm:text-xl md:text-2xl">
          Small Heading
        </h4>
      </Stack>

      <!-- Heading Variants -->
      <Heading level={3} size="sm" variant="default">
        Heading Variants
      </Heading>
      <Stack gap={2}>
        <h3 class="font-display font-bold tracking-tight text-foreground selection:bg-primary/30">Default</h3>
        <h3 class="text-gradient-primary bg-linear-to-br from-primary via-primary/80 to-primary/60 bg-clip-text font-display font-bold tracking-tight text-transparent selection:bg-primary/30">
          Primary Gradient
        </h3>
        <h3 class="text-gradient-accent bg-linear-to-br from-accent via-accent/80 to-accent/60 bg-clip-text font-display font-bold tracking-tight text-transparent selection:bg-primary/30">
          Accent Gradient
        </h3>
        <h3 class="font-display font-bold font-medium tracking-tight text-muted-foreground selection:bg-primary/30">
          Muted
        </h3>
      </Stack>

      <!-- Text Sizes -->
      <Heading level={3} size="sm" variant="default">
        Text Sizes
      </Heading>
      <Stack gap={2}>
        <p class="text-[0.9375rem] leading-[1.6] text-foreground opacity-80">Base text (0.9375rem)</p>
        <p class="text-[1.125rem] leading-[1.6] font-medium text-foreground opacity-80">Large text (1.125rem)</p>
        <p class="text-[0.8125rem] leading-[1.6] text-foreground opacity-80">Small text (0.8125rem)</p>
        <p class="text-[0.6875rem] leading-[1.6] text-foreground opacity-80">Extra small text (0.6875rem)</p>
      </Stack>

      <!-- Text Variants -->
      <Heading level={3} size="sm" variant="default">
        Text Variants
      </Heading>
      <Stack gap={2}>
        <p class="text-[0.9375rem] leading-[1.6] text-foreground opacity-80">Default text</p>
        <p class="text-[0.9375rem] leading-[1.6] font-medium text-primary opacity-80">Primary text</p>
        <p class="text-[0.9375rem] leading-[1.6] font-medium text-accent opacity-80">Accent text</p>
        <p class="text-[0.9375rem] leading-[1.6] text-muted-foreground opacity-80">Muted text</p>
      </Stack>
    </Stack>

    <Separator />

    <!-- Stack Section -->
    <Stack gap={4}>
      <Heading level={2} size="lg" variant="accent">
        Stack
      </Heading>
      <Text variant="muted">
        Flexible layout component for stacking elements with consistent gaps.
      </Text>

      <!-- Directions -->
      <Heading level={3} size="sm" variant="default">
        Direction
      </Heading>
      <Stack direction="row" gap={4} wrap="wrap">
        <div class="flex rounded-lg border border-border bg-muted/20 p-4">
          <Stack gap={2}>
            <div class="flex h-8 items-center justify-center rounded-sm border border-primary/30 bg-primary/20 text-xs text-primary">Item 1</div>
            <div class="flex h-8 items-center justify-center rounded-sm border border-primary/30 bg-primary/20 text-xs text-primary">Item 2</div>
            <div class="flex h-8 items-center justify-center rounded-sm border border-primary/30 bg-primary/20 text-xs text-primary">Item 3</div>
          </Stack>
        </div>
        <div class="flex rounded-lg border border-border bg-muted/20 p-4">
          <Stack direction="row" gap={2}>
            <div class="flex size-8 items-center justify-center rounded-sm border border-secondary/30 bg-secondary/20 text-xs text-secondary">1</div>
            <div class="flex size-8 items-center justify-center rounded-sm border border-secondary/30 bg-secondary/20 text-xs text-secondary">2</div>
            <div class="flex size-8 items-center justify-center rounded-sm border border-secondary/30 bg-secondary/20 text-xs text-secondary">3</div>
          </Stack>
        </div>
      </Stack>

      <!-- Gaps -->
      <Heading level={3} size="sm" variant="default">
        Gap
      </Heading>
      <Stack gap={4} wrap="wrap">
        <Stack gap={1}>
          <Text size="sm" variant="muted">gap-1</Text>
          <Stack direction="row" gap={1}>
            <div class="size-8 rounded-sm border border-accent/30 bg-accent/20"></div>
            <div class="size-8 rounded-sm border border-accent/30 bg-accent/20"></div>
            <div class="size-8 rounded-sm border border-accent/30 bg-accent/20"></div>
          </Stack>
        </Stack>
        <Stack gap={2}>
          <Text size="sm" variant="muted">gap-2</Text>
          <Stack direction="row" gap={2}>
            <div class="size-8 rounded-sm border border-accent/30 bg-accent/20"></div>
            <div class="size-8 rounded-sm border border-accent/30 bg-accent/20"></div>
            <div class="size-8 rounded-sm border border-accent/30 bg-accent/20"></div>
          </Stack>
        </Stack>
        <Stack gap={3}>
          <Text size="sm" variant="muted">gap-3</Text>
          <Stack direction="row" gap={3}>
            <div class="size-8 rounded-sm border border-accent/30 bg-accent/20"></div>
            <div class="size-8 rounded-sm border border-accent/30 bg-accent/20"></div>
            <div class="size-8 rounded-sm border border-accent/30 bg-accent/20"></div>
          </Stack>
        </Stack>
        <Stack gap={4}>
          <Text size="sm" variant="muted">gap-4</Text>
          <Stack direction="row" gap={4}>
